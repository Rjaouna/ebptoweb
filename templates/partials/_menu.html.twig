{# templates/partials/_menu.html.twig #}
{% set route = app.request.attributes.get('_route') %}
{% set userEmail = app.user ? (app.user.email|default('Compte')) : '' %}
{% set userInitial = userEmail ? userEmail|slice(0,1)|upper : 'U' %}

<header class="sticky-top">
  <nav class="navbar navbar-expand-lg app-navbar border-bottom">
    <div class="container-fluid px-3 px-lg-4">

      {# Brand #}
      <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('app_home') }}">
        <span class="brand-logo">
          <img src="{{ asset('img/logo.png') }}" alt="Hopic" loading="lazy">
        </span>
      </a>

    {# Desktop nav (centre, discret) #}
<div class="d-none d-lg-flex align-items-center gap-3 app-center-nav">
  <a class="app-link {{ route == 'app_home' ? 'active' : '' }}"
     href="{{ path('app_home') }}">
    <i class="bi bi-house-door me-2"></i>Accueil
  </a>

  <a class="app-link {{ route starts with 'catalogue_' or route == 'catalogue_index' ? 'active' : '' }}"
     href="{{ path('catalogue_index') }}">
    <i class="bi bi-grid-3x3-gap me-2"></i>Catalogue
  </a>

  <a class="app-link {{ route == 'catalogue_new' ? 'active' : '' }}"
     href="{{ path('catalogue_new') }}">
    <i class="bi bi-stars me-2"></i>Nouveautés
  </a>

  <a class="app-link {{ route starts with 'orders_' ? 'active' : '' }}"
     href="{{ path('orders_index') }}">
    <i class="bi bi-receipt me-2"></i>Mes commandes
  </a>


 

</div>


      {# Right actions (desktop) #}
      <div class="ms-auto d-none d-lg-flex align-items-center gap-2">

        {% if app.user %}
          {# Panier : offcanvas sur Catalogue sinon lien normal #}
          <a id="cartBtn" href="{{ path('cart_index') }}"
             class="btn btn-outline-secondary rounded-pill position-relative px-3">
            <i class="bi bi-cart3"></i>
            <span class="d-none d-xl-inline ms-2 fw-semibold">Panier</span>
            <span id="cartBadge"
                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary">
              0
            </span>
          </a>

          {# Compte dropdown minimal #}
          <div class="dropdown">
            <button class="btn btn-light app-avatar-btn rounded-pill px-2"
                    type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Compte">
              <span class="app-avatar">{{ userInitial }}</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end app-dropdown">
              <li class="px-3 py-2">
                <div class="small text-secondary">Connecté en</div>
                <div class="fw-semibold text-truncate" style="max-width:260px;">{{ userEmail }}</div>
              </li>
              <li><hr class="dropdown-divider"></li>

              <li>
                <a class="dropdown-item" href="{{ path('orders_index') }}">
                  <i class="bi bi-receipt me-2"></i>Mes commandes
                </a>
              </li>
              <li>
                <a class="dropdown-item" href="{{ path('cart_index') }}">
                  <i class="bi bi-cart3 me-2"></i>Mon panier
                </a>
              </li>

              {% if is_granted('ROLE_ADMIN') %}
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/admin"><i class="bi bi-speedometer2 me-2"></i>Admin</a></li>
                <li><a class="dropdown-item" href="/admin/articles"><i class="bi bi-boxes me-2"></i>Articles</a></li>
                <li><a class="dropdown-item" href="/admin/integrations/ftp"><i class="bi bi-cloud-arrow-up me-2"></i>FTP / CSV</a></li>
                 <li><a class="dropdown-item" href="{{ path('admin_orders_index') }}">
  <i class="bi bi-receipt me-2"></i>Commandes (Admin)
</a></li>
              {% endif %}
{% if app.environment == 'dev' and is_granted('IS_AUTHENTICATED_FULLY') %}
          <a class="topbar-link" id="btnDevResetDb" type="button">
            vider
          </a>
        {% endif %}
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item text-danger" href="/logout">
                  <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
                </a>
              </li>
            </ul>
          </div>

        {% else %}
          <a href="/login" class="btn btn-primary rounded-pill px-3">
            <i class="bi bi-box-arrow-in-right"></i>
            <span class="ms-2 fw-semibold">Se connecter</span>
          </a>
        {% endif %}

      
      </div>

      {# Mobile: only burger (opens mega offcanvas) #}
      <div class="ms-auto d-flex d-lg-none align-items-center">
        <button class="btn btn-light rounded-pill px-3 app-burger"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#mobileMega"
                aria-controls="mobileMega"
                aria-label="Menu">
          <i class="bi bi-list"></i>
        </button>
      </div>

    </div>
  </nav>
</header>

{# ======================
   MOBILE MEGA MENU
   ====================== #}
<div class="offcanvas offcanvas-end app-mega" tabindex="-1" id="mobileMega" aria-labelledby="mobileMegaLabel">
  <div class="offcanvas-header app-mega-head">
    <div class="d-flex align-items-center gap-2">
      <span class="brand-mark">
        <img src="{{ asset('img/logo.png') }}" alt="Hopic" loading="lazy">
      </span>
      <div class="lh-sm">
        <div class="fw-black" id="mobileMegaLabel">Menu</div>
        <div class="text-muted small">Commande, panier & compte</div>
      </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
  </div>

  <div class="offcanvas-body app-mega-body">


    {# Primary nav #}
    <div class="app-section-title">Navigation</div>
    <div class="d-grid gap-2 mb-3">
      <a class="app-mega-link {{ route == 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}">
        <i class="bi bi-house-door"></i><span>Accueil</span>
      </a>

      <a class="app-mega-link {{  route == 'catalogue_index' ? 'active' : '' }}" href="{{ path('catalogue_index') }}">
        <i class="bi bi-grid-3x3-gap"></i><span>Catalogue</span>
      </a>

      <a class="app-mega-link {{ route == 'catalogue_new' ? 'active' : '' }}" href="{{ path('catalogue_new') }}">
        <i class="bi bi-stars"></i><span>Nouveautés</span>
      </a>
      

      {% if app.user %}
        <a class="app-mega-link {{ route starts with 'orders_' ? 'active' : '' }}" href="{{ path('orders_index') }}">
          <i class="bi bi-receipt"></i><span>Mes commandes</span>
        </a>

        <a class="app-mega-link {{ route starts with 'cart_' ? 'active' : '' }}" href="{{ path('cart_index') }}">
          <i class="bi bi-cart3"></i><span>Mon panier</span>
        </a>
      {% endif %}
    </div>

    {# Account block #}
    <div class="app-section-title">Compte</div>
    <div class="app-account card border-0 rounded-4 mb-3">
      <div class="card-body p-3">
        {% if app.user %}
          <div class="d-flex align-items-center gap-2">
            <div class="app-avatar-lg">{{ userInitial }}</div>
            <div class="min-w-0">
              <div class="fw-semibold text-truncate">{{ userEmail }}</div>
              <div class="small text-muted">Espace client</div>
            </div>
          </div>

          <div class="d-grid gap-2 mt-3">
            <a class="btn btn-outline-secondary rounded-pill" href="{{ path('orders_index') }}">
              <i class="bi bi-receipt me-2"></i>Voir mes commandes
            </a>
            <a class="btn btn-outline-secondary rounded-pill" href="{{ path('cart_index') }}">
              <i class="bi bi-cart3 me-2"></i>Voir mon panier
            </a>

            {% if is_granted('ROLE_ADMIN') %}
              <a class="btn btn-outline-secondary rounded-pill" href="/admin">
                <i class="bi bi-speedometer2 me-2"></i>Admin
              </a>
              <a class="btn btn-outline-secondary rounded-pill" href="/admin/integrations/ftp">
                <i class="bi bi-cloud-arrow-up me-2"></i>FTP / CSV
              </a>
            {% endif %}

            <a class="btn btn-danger rounded-pill" href="/logout">
              <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
            </a>
          </div>
        {% else %}
          <div class="small text-muted mb-2">Connecte-toi pour passer commande et suivre tes achats.</div>
          <div class="d-grid gap-2">
            <a class="btn btn-primary rounded-pill" href="/login">
              <i class="bi bi-box-arrow-in-right me-2"></i>Connexion
            </a>
          </div>
        {% endif %}
      </div>
    </div>

    {# Social / contact quick links #}
    <div class="app-section-title">Réseaux</div>
    <div class="d-flex gap-2 flex-wrap">
      <a class="app-social" href="#" target="_blank" rel="noopener nofollow" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
      <a class="app-social" href="#" target="_blank" rel="noopener nofollow" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
      <a class="app-social" href="#" target="_blank" rel="noopener nofollow" aria-label="Google"><i class="bi bi-google"></i></a>
    </div>

    {% if app.environment == 'dev' and is_granted('IS_AUTHENTICATED_FULLY') %}
      <hr class="my-3">
      <button class="btn btn-danger w-100 rounded-pill" id="btnDevResetDbMobile" type="button">
        <i class="bi bi-trash3 me-2"></i>
      </button>
    {% endif %}

  </div>
</div>

<style>
