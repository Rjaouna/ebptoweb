    padding: .62rem .75rem;
  }
  .app-dropdown .dropdown-item i{ width:20px; display:inline-block; }

  /* Badge panier */
  #cartBadge{
    min-width: 22px;
    height: 22px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    font-size: .75rem;
