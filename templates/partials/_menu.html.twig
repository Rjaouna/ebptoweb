{# templates/partials/_menu.html.twig #}
{% set route = app.request.attributes.get('_route') %}
{% set userEmail = app.user ? (app.user.email|default('Compte')) : '' %}
{% set userInitial = userEmail ? userEmail|slice(0,1)|upper : 'U' %}

<header class="sticky-top">
  <nav class="navbar navbar-expand-lg bg-body app-navbar border-bottom">
    <div class="container-fluid px-3 px-lg-4">

      {# Brand #}
  <a class="navbar-brand d-flex align-items-center gap-2" href="/">
  <span class="brand-logo">
    <img src="{{ asset('img/logo.png') }}" alt="EBPToWeb" loading="lazy">
  </span>

</a>


      {# Desktop nav #}
      <div class="d-none d-lg-flex align-items-center gap-2 ms-lg-3">
        <a class="nav-link app-pill {{ route starts with 'catalogue' ? 'active' : '' }}"
           href="{{ path('catalogue_index') }}">
          <i class="bi bi-grid-3x3-gap me-2"></i>Catalogue
        </a>

        <a class="nav-link app-pill {{ route == 'catalogue_new' ? 'active' : '' }}"
           href="{{ path('catalogue_new') }}">
          <i class="bi bi-stars me-2"></i>Nouveautés
        </a>

        <a class="nav-link app-pill {{ route == 'admin_ftp_config' ? 'active' : '' }}"
           href="/admin/integrations/ftp">
          <i class="bi bi-cloud-arrow-up me-2"></i>FTP / CSV
        </a>
      </div>

      {# Right actions #}
      <div class="ms-auto d-flex align-items-center gap-2">

        {% if app.user %}
          {# Panier : offcanvas sur Catalogue sinon lien normal #}
          <a id="cartBtn" href="{{ path('cart_index') }}"
             class="btn btn-outline-secondary rounded-pill position-relative px-3 mx-2">
            <i class="bi bi-cart3"></i>
            <span class="d-none d-md-inline ms-2 fw-semibold">Panier</span>
            <span id="cartBadge"
                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary">
              0
            </span>
          </a>
        {% else %}
          <a href="/login" class="btn btn-primary rounded-pill px-3">
            <i class="bi bi-box-arrow-in-right"></i>
            <span class="d-none d-md-inline ms-2 fw-semibold">Se connecter</span>
          </a>
        {% endif %}

        {# Compte dropdown (desktop + mobile) #}
        <div class="dropdown">
          <button class="btn btn-light"
                  type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="app-avatar">{{ userInitial }}</span>
         
          </button>

          <ul class="dropdown-menu dropdown-menu-end app-dropdown">
            {% if app.user %}
              <li class="px-3 py-2">
                <div class="small text-secondary">Connecté en</div>
                <div class="fw-semibold text-truncate" style="max-width:260px;">{{ userEmail }}</div>
              </li>
              <li><hr class="dropdown-divider"></li>

              {% if is_granted('ROLE_ADMIN') %}
                <li><a class="dropdown-item" href="/admin"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                <li><a class="dropdown-item" href="/admin/articles"><i class="bi bi-boxes me-2"></i>Articles</a></li>
                <li><a class="dropdown-item" href="/admin/integrations/ftp"><i class="bi bi-gear me-2"></i>Configuration FTP</a></li>
                <li><hr class="dropdown-divider"></li>
              {% endif %}

              <li>
                <a class="dropdown-item text-danger" href="/logout">
                  <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
                </a>
              </li>
            {% else %}
              <li>
                <a class="dropdown-item" href="/login">
                  <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                </a>
              </li>
            {% endif %}
          </ul>
        </div>

        {# Mobile menu button #}
        <button class="btn btn-light rounded-pill px-3 d-lg-none"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#mobileNav"
                aria-controls="mobileNav"
                aria-label="Menu">
          <i class="bi bi-list"></i>
        </button>
      </div>

    </div>
  </nav>
</header>

{# ✅ Mobile Offcanvas Nav #}
<div class="offcanvas offcanvas-end" tabindex="-1" id="mobileNav" aria-labelledby="mobileNavLabel">
  <div class="offcanvas-header">
    <div class="d-flex align-items-center gap-2">
      <span class="brand-mark"><i class="bi bi-box-seam"></i></span>
      <div class="lh-sm">
        <div class="fw-bold" id="mobileNavLabel">Menu</div>
        <div class="text-secondary small">Navigation</div>
      </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>

  <div class="offcanvas-body">
    <div class="d-grid gap-2">

      <a class="btn btn-light text-start app-mobile-link {{ route starts with 'catalogue' ? 'active' : '' }}"
         href="{{ path('catalogue_index') }}">
        <i class="bi bi-grid-3x3-gap me-2"></i> Catalogue
      </a>

      <a class="btn btn-light text-start app-mobile-link {{ route == 'catalogue_new' ? 'active' : '' }}"
         href="{{ path('catalogue_new') }}">
        <i class="bi bi-stars me-2"></i> Nouveautés
      </a>

      <a class="btn btn-light text-start app-mobile-link {{ route == 'admin_ftp_config' ? 'active' : '' }}"
         href="/admin/integrations/ftp">
        <i class="bi bi-cloud-arrow-up me-2"></i> FTP / CSV
      </a>

      <a class="btn btn-outline-secondary text-start app-mobile-link" href="{{ path('cart_index') }}">
        <i class="bi bi-receipt-cutoff me-2"></i> Panier / Devis
      </a>

      <hr class="my-3">

      {% if app.user %}
        <a class="btn btn-outline-danger text-start app-mobile-link" href="/logout">
          <i class="bi bi-box-arrow-right me-2"></i> Déconnexion
        </a>
      {% else %}
        <a class="btn btn-primary text-start app-mobile-link" href="/login">
          <i class="bi bi-box-arrow-in-right me-2"></i> Se connecter
        </a>
      {% endif %}
    </div>
  </div>
</div>

<style>
  /* Menu look modern (sans topbar) */
  .app-navbar{
    background: rgba(255,255,255,.86) !important;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }
  .brand-mark{
    width:40px;height:40px;
    border-radius:14px;
    display:grid;place-items:center;
    background: var(--bs-primary);
    color:#fff;
    box-shadow: 0 12px 26px rgba(2,6,23,.14);
  }

  .app-pill{
    border-radius:999px;
    padding:.55rem .95rem;
    font-weight:800;
    color: var(--bs-secondary);
    transition: all .18s ease;
  }
  .app-pill:hover{
    background: rgba(17,24,39,.06);
  }
  .app-pill.active{
    background: rgba(var(--bs-primary-rgb), .12);
    color: var(--bs-primary);
  }

  /* Avatar button */
  .app-avatar-btn{
    border: 1px solid rgba(0,0,0,.08);
    transition: transform .18s ease, box-shadow .18s ease;
  }
  .app-avatar-btn:hover{
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(2,6,23,.10);
  }
  .app-avatar{
    width:34px;height:34px;
    border-radius:999px;
    display:grid;place-items:center;
    font-weight:900;
    background: rgba(var(--bs-primary-rgb), .12);
    color: var(--bs-primary);
    border: 1px solid rgba(var(--bs-primary-rgb), .18);
  }

  .app-dropdown{
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 18px 40px rgba(0,0,0,.12);
    padding: .5rem;
    min-width: 280px;
  }
  .app-dropdown .dropdown-item{
    border-radius: 12px;
    padding: .6rem .75rem;
  }
  .app-dropdown .dropdown-item i{ width:20px; display:inline-block; }

  /* Mobile links */
  .app-mobile-link{
    border-radius: 14px;
    padding: .75rem .9rem;
    border: 1px solid rgba(15,23,42,.08);
    background: rgba(255,255,255,.92);
  }
  .app-mobile-link.active{
    border-color: rgba(var(--bs-primary-rgb), .30);
    background: rgba(var(--bs-primary-rgb), .10);
    color: var(--bs-primary);
    font-weight: 900;
  }

  /* Badge */
  #cartBadge{
    min-width: 22px;
    height: 22px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    font-size: .75rem;
    border: 2px solid rgba(255,255,255,.95);
  }
</style>

{# ✅ Panier : offcanvas seulement sur Catalogue, sinon redirection vers cart_index #}
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("cartBtn");
    if (!btn) return;

    btn.addEventListener("click", (e) => {
      // sur catalogue : ouvrir offcanvas
      if (window.CATALOG_CONFIG) {
        const cartCanvas = document.getElementById("cartCanvas");
        if (!cartCanvas) return; // pas d'offcanvas => laisse le lien

        e.preventDefault();
        try { window.CartUI?.sync?.(); } catch(_) {}

        try {
          bootstrap.Offcanvas.getOrCreateInstance(cartCanvas).show();
        } catch(err) {
          console.error(err);
          window.location.href = btn.getAttribute("href");
        }
      }
      // ailleurs : pas de preventDefault => redirection normale
    });
  });
</script>
