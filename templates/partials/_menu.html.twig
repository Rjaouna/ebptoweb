  }
  .app-mega-link.active{
    border-color: rgba(var(--bs-primary-rgb), .28);
    background: rgba(var(--bs-primary-rgb), .10);
    color: var(--bs-primary);
  }
  .app-mega-link.active i{ color: var(--bs-primary); }

  .app-account{
    background: rgba(255,255,255,.86);
    border: 1px solid rgba(15,23,42,.08);
    box-shadow: 0 14px 30px rgba(2,6,23,.08);
  }
  .app-avatar-lg{
    width:44px;height:44px;
    border-radius: 999px;
    display:grid;place-items:center;
    font-weight: 900;
    background: rgba(var(--bs-primary-rgb), .12);
    color: var(--bs-primary);
    border: 1px solid rgba(var(--bs-primary-rgb), .18);
    flex: 0 0 auto;
  }

  .app-social{
    width: 42px;
    height: 42px;
    border-radius: 999px;
    display:grid;
    place-items:center;
    text-decoration:none;
    background: rgba(255,255,255,.92);
    border: 1px solid rgba(15,23,42,.10);
    color: rgba(47,52,59,.86);
    transition: transform .12s ease, box-shadow .12s ease, color .12s ease;
  }
  .app-social:hover{
    transform: translateY(-1px);
    box-shadow: 0 16px 30px rgba(2,6,23,.10);
    color: var(--bs-primary);
    border-color: rgba(var(--bs-primary-rgb), .18);
  }
</style>

{# ✅ Panier : offcanvas seulement sur Catalogue, sinon redirection vers cart_index #}
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("cartBtn");
    if (!btn) return;

    btn.addEventListener("click", (e) => {
      // sur catalogue : ouvrir offcanvas
      if (window.CATALOG_CONFIG) {
        const cartCanvas = document.getElementById("cartCanvas");
        if (!cartCanvas) return;

        e.preventDefault();
        try { window.CartUI?.sync?.(); } catch(_) {}

        try {
          bootstrap.Offcanvas.getOrCreateInstance(cartCanvas).show();
        } catch(err) {
          console.error(err);
          window.location.href = btn.getAttribute("href");
        }
      }
    });
  });
</script>

{# ✅ DEV reset DB (desktop + mobile) #}
{% if app.environment == 'dev' and is_granted('IS_AUTHENTICATED_FULLY') %}
<script>
  (function(){
    const endpoint = "{{ path('dev_reset_db') }}";

    async function run(btn){
      if(!confirm("Vider Cart / CartItem / Commande / CommandeLigne / StockReservation ?")) return;
      btn.disabled = true;

      try{
        const res = await fetch(endpoint, {
          method: "POST",
          credentials: "same-origin",
          headers: { "X-Requested-With": "XMLHttpRequest", "Accept": "application/json" },
        });

        const data = await res.json().catch(() => null);

        if (!res.ok || !data?.ok) {
          alert("Erreur reset DB: " + (data?.message || ("HTTP " + res.status)));
          return;
        }

        alert("✅ DB vidée !");
        window.location.reload();
      }catch(e){
        alert("Erreur réseau.");
      }finally{
        btn.disabled = false;
      }
    }

    const d = document.getElementById("btnDevResetDb");
    const m = document.getElementById("btnDevResetDbMobile");
    if(d) d.addEventListener("click", () => run(d));
    if(m) m.addEventListener("click", () => run(m));
  })();
</script>
{% endif %}
