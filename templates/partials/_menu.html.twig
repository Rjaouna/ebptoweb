  }

  /* Mega offcanvas */
  .app-mega{ --bs-offcanvas-width: min(92vw, 420px); }
  .app-mega-head{
    background: rgba(255,255,255,.92);
    border-bottom: 1px solid rgba(15,23,42,.08);
    backdrop-filter: blur(14px);
  }
  .app-mega-body{
    background:
      radial-gradient(900px 400px at 20% 0%, rgba(var(--bs-primary-rgb), .10), transparent 55%),
      radial-gradient(900px 400px at 90% 0%, rgba(47,52,59,.08), transparent 55%),
