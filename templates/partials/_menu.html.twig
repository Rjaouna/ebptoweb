    background: rgba(255,255,255,.86) !important;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(15,23,42,.08) !important;
  }

  /* Brand */
  .brand-logo{
    width: 145px;
    height: 70px;
    border-radius: 14px;
    display: grid;
    place-items: center;
  }
  .brand-logo img{
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: 6px;
  }

  /* Center desktop nav */
  .app-center-nav{
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
  }
  .navbar-brand, .ms-auto{
    position: relative;
    z-index: 2;
  }

  /* Desktop links: discreet, pro */
  .app-link{
    text-decoration: none;
    color: rgba(47,52,59,.92);
    font-weight: 800;
    font-size: .92rem;
    padding: .35rem .2rem;
    position: relative;
    transition: color .15s ease, opacity .15s ease;
    opacity: .92;
  }
  .app-link:hover{ color: var(--bs-primary); opacity: 1; }
  .app-link.active{ color: var(--bs-primary); opacity: 1; }
 

  /* Avatar */
  .app-avatar-btn{
    border: 1px solid rgba(0,0,0,.08);
    transition: transform .18s ease, box-shadow .18s ease;
    background: rgba(255,255,255,.80);
  }
  .app-avatar-btn:hover{
