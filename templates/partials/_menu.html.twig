{# templates/partials/_menu.html.twig #}
{% set route = app.request.attributes.get('_route') %}

{# ---- Initiales user ---- #}
{% set userLabel = app.user ? (app.user.email|default('User')) : 'Guest' %}
{% set userInitials = userLabel|slice(0,1)|upper %}

<style>
	.app-topbar {
		position: sticky;
		top: 0;
		z-index: 1030;
		background: rgba(255, 255, 255, .82);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(0, 0, 0, .06);
	}
	.app-topbar .brand-mark {
		width: 38px;
		height: 38px;
		border-radius: 12px;
		display: grid;
		place-items: center;
		background: #111;
		color: #fff;
		box-shadow: 0 10px 22px rgba(0, 0, 0, .10);
	}
	.app-topbar .nav-pill {
		border-radius: 999px;
		padding: 0.55rem 0.95rem;
		font-weight: 600;
		color: #1b1f24;
		transition: all 0.18s ease;
	}
	.app-topbar .nav-pill:hover {
		background: rgba(0, 0, 0, .05);
	}
	.app-topbar .nav-pill.active {
		background: rgba(13, 110, 253, .12);
		color: #0d6efd;
	}

	.app-topbar .icon-btn {
		border-radius: 999px;
		padding: 0.55rem 0.85rem;
		border: 1px solid rgba(0, 0, 0, .10);
		background: #fff;
		transition: all 0.18s ease;
	}
	.app-topbar .icon-btn:hover {
		transform: translateY(-1px);
		box-shadow: 0 10px 18px rgba(0, 0, 0, .08);
	}
	.app-topbar .cart-badge {
		font-size: 0.72rem;
		border-radius: 999px;
		padding: 0.18rem 0.45rem;
	}
	.app-topbar .avatar {
		width: 38px;
		height: 38px;
		border-radius: 999px;
		display: grid;
		place-items: center;
		font-weight: 800;
		letter-spacing: 0.02em;
		background: linear-gradient(135deg, rgba(13,110,253,.18), rgba(111,66,193,.18));
		border: 1px solid rgba(0, 0, 0, .08);
		color: #1b1f24;
		user-select: none;
	}

	.app-topbar .dropdown-menu {
		border-radius: 14px;
		border: 1px solid rgba(0, 0, 0, .06);
		box-shadow: 0 18px 40px rgba(0, 0, 0, .12);
		padding: 0.5rem;
	}
	.app-topbar .dropdown-item {
		border-radius: 12px;
		padding: 0.6rem 0.75rem;
	}
	.app-topbar .dropdown-item i {
		width: 20px;
		display: inline-block;
	}

	/* Cart offcanvas UX */
	.cart-item {
		display: flex;
		gap: 0.75rem;
		align-items: center;
		border: 1px solid rgba(0, 0, 0, .08);
		border-radius: 16px;
		padding: 0.6rem 0.65rem;
		background: #fff;
	}
	.cart-thumb {
		width: 56px;
		height: 56px;
		border-radius: 14px;
		border: 1px solid rgba(0, 0, 0, .08);
		overflow: hidden;
		background: #f8f9fa;
		display: grid;
		place-items: center;
		flex: 0 0 auto;
	}
	.cart-thumb img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		background: #fff;
		display: block;
	}
	.cart-meta {
		min-width: 0;
		flex: 1;
	}
	.cart-title {
		font-weight: 700;
		font-size: 0.95rem;
		line-height: 1.1;
	}
	.cart-sub {
		font-size: 0.78rem;
		color: #6c757d;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.qty-ctrl {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}
	.qty-ctrl .btn {
		border-radius: 10px;
	}
	.qty-ctrl input {
		width: 54px;
		text-align: center;
		border-radius: 12px;
	}
</style>

<header class="app-topbar">
	<div class="container-fluid px-3 px-lg-4">
		<div
			class="d-flex align-items-center justify-content-between py-2">

			{# --- Brand --- #}
			<a href="/" class="text-decoration-none d-flex align-items-center gap-2">
				<span class="brand-mark">
					<i class="bi bi-box-seam"></i>
				</span>
				<div class="d-flex flex-column lh-sm">
					<span class="fw-bold" style="font-size:1.02rem;color:#111;">EBPToWeb</span>
					<span class="text-muted" style="font-size:.78rem;">Catalogue & export</span>
				</div>
			</a>

			{# --- Center nav (desktop) --- #}
			<nav class="d-none d-lg-flex align-items-center gap-1">
				<a class="nav-pill text-decoration-none {% if route starts with 'catalogue' %}active{% endif %}" href="{{ path('catalogue_index') }}">
					<i class="bi bi-grid-3x3-gap me-2"></i>Catalogue
				</a>

				<a class="nav-pill text-decoration-none {% if route == 'admin_ftp_config' %}active{% endif %}" href="/admin/integrations/ftp">
					<i class="bi bi-cloud-arrow-up me-2"></i>FTP / CSV
				</a>




<a class="nav-pill text-decoration-none {% if route == 'catalogue_new' %}active{% endif %}" href="{{ path('catalogue_new') }}">
	<i class="bi bi-stars me-2"></i>Nouveautés
</a>


			</nav>

			{# --- Right actions --- #}
			<div
				class="d-flex align-items-center gap-2">

				{# ✅ SEUL BOUTON PANIER (MENU) #}
				{% if app.user %}
<a id="cartBtn" href="{{ path('cart_index') }}" class="icon-btn text-decoration-none d-flex align-items-center gap-2">
	<i class="bi bi-cart3"></i>
	<span class="d-none d-md-inline fw-semibold">Panier</span>
	<span id="cartBadge" class="badge bg-secondary cart-badge">0</span>
</a>

				{% else %}
					<a href="/login" class="icon-btn text-decoration-none d-flex align-items-center gap-2">
						<i class="bi bi-box-arrow-in-right"></i>
						<span class="d-none d-md-inline fw-semibold">Se connecter</span>
					</a>
				{% endif %}

				{# Mobile menu trigger #}
				<button class="icon-btn d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileNav" aria-controls="mobileNav">
					<i class="bi bi-list"></i>
				</button>

				{# User dropdown #}
				<div class="dropdown">
					<button class="btn p-0 border-0 bg-transparent" type="button" data-bs-toggle="dropdown" aria-expanded="false">
						<div class="d-flex align-items-center gap-2">
							<div class="avatar">{{ userInitials }}</div>
							<div class="d-none d-md-flex flex-column align-items-start lh-sm">
								<span class="fw-semibold" style="font-size:.92rem;">{{ app.user ? 'Compte' : 'Invité' }}</span>
								<span class="text-muted" style="font-size:.78rem;">
									{{ app.user ? (app.user.email|default('')) : 'Se connecter' }}
								</span>
							</div>
							<i class="bi bi-chevron-down text-muted d-none d-md-inline"></i>
						</div>
					</button>

					<ul class="dropdown-menu dropdown-menu-end">
						{% if app.user %}
							<li>
								<span class="dropdown-item-text text-muted small">
									<i class="bi bi-person me-2"></i>
									{{ app.user.email }}
								</span>
							</li>
							<li><hr class="dropdown-divider"></li>

							{% if is_granted('ROLE_ADMIN') %}
								<li>
									<a class="dropdown-item" href="/admin">
										<i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
								</li>
								<li>
									<a class="dropdown-item" href="/admin/articles">
										<i class="bi bi-boxes me-2"></i>Articles</a>
								</li>
								<li>
									<a class="dropdown-item" href="/admin/integrations/ftp">
										<i class="bi bi-gear me-2"></i>Configuration FTP</a>
								</li>
								<li><hr class="dropdown-divider"></li>
							{% endif %}

							<li>
								<a class="dropdown-item text-danger" href="/logout">
									<i class="bi bi-box-arrow-right me-2"></i>Déconnexion</a>
							</li>
						{% else %}
							<li>
								<a class="dropdown-item" href="/login">
									<i class="bi bi-box-arrow-in-right me-2"></i>Se connecter</a>
							</li>
						{% endif %}
					</ul>
				</div>

			</div>
		</div>
	</div>

	{# --- Mobile Offcanvas --- #}
	<div class="offcanvas offcanvas-end" tabindex="-1" id="mobileNav" aria-labelledby="mobileNavLabel">
		<div class="offcanvas-header">
			<h5 class="offcanvas-title" id="mobileNavLabel">Menu</h5>
			<button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
		</div>
		<div class="offcanvas-body">
			<div class="d-grid gap-2">
				<a class="btn btn-outline-dark text-start" href="{{ path('catalogue_index') }}">
					<i class="bi bi-grid-3x3-gap me-2"></i>Catalogue
				</a>
				<a class="btn btn-outline-dark text-start" href="/admin/integrations/ftp">
					<i class="bi bi-cloud-arrow-up me-2"></i>FTP / CSV
				</a>
				<a class="btn btn-outline-dark text-start" href="{{ path('cart_index') }}">
					<i class="bi bi-receipt-cutoff me-2"></i>Devis
				</a>
<a class="btn btn-outline-dark text-start" href="{{ path('catalogue_new') }}">
	<i class="bi bi-stars me-2"></i>Nouveautés
</a>


			</div>
		</div>
	</div>
</header>

{# ✅ OFFCANVAS PANIER GLOBAL #}
<div class="offcanvas offcanvas-end" tabindex="-1" id="cartCanvas" aria-labelledby="cartCanvasLabel">
	<div class="offcanvas-header">
		<h5 class="offcanvas-title" id="cartCanvasLabel">
			<i class="bi bi-cart3 me-2"></i>Panier</h5>
		<button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
	</div>

	<div class="offcanvas-body">
		<div id="cartEmpty" class="text-center text-muted py-4">
			Votre panier est vide.
			<div class="small mt-2">Ajoutez des articles depuis le catalogue.</div>
		</div>

		<div class="d-grid gap-2" id="cartSummary"></div>

		<div class="d-flex gap-2 mt-3">
			<button class="btn btn-outline-danger w-100" id="btnCartClear" type="button">
				<i class="bi bi-trash"></i>
				Vider
			</button>
			<a class="btn btn-primary w-100" href="{{ path('cart_index') }}">
				<i class="bi bi-bag-check"></i>
				Passer la commande
			</a>
		</div>
	</div>

	<div class="p-3 border-top">
		<div class="d-flex align-items-center justify-content-between">
			<div class="fw-semibold">Total estimé</div>
			<div class="fw-semibold" id="cartTotal">—</div>
		</div>
		<div class="small text-muted mt-1">* Prix estimatif via CSV (si disponible)</div>
	</div>
</div>

{# ✅ ENDPOINTS JS accessibles partout #}
 <script>
  window.CART_ENDPOINTS = {
    state: "{{ path('cart_state') }}",
    add: "{{ path('cart_add') }}",
    set: "{{ path('cart_set') }}",
    remove: "{{ path('cart_remove') }}",
    clear: "{{ path('cart_clear') }}",
    index: "{{ path('cart_index') }}"
  };

  // config images (utilisé partout)
  window.CATALOG_CONFIG = window.CATALOG_CONFIG || {
    imagesBase: "http://catalogue.3skpartsauto.com/export_images",
    locale: "fr-FR",
    currency: "MAD",
    priceMode: "inc" // TTC
  };

  // Cart UI global
  (function(){
    const E = window.CART_ENDPOINTS;
    if(!E) return;

    let cartState = {};
    let lastSync = 0;

    const badge = document.getElementById("cartBadge");
    const emptyEl = document.getElementById("cartEmpty");
    const listEl  = document.getElementById("cartSummary");
    const totalEl = document.getElementById("cartTotal");
    const btnClear = document.getElementById("btnCartClear");

    function toNumber(v){
      const n = Number(String(v ?? "").replace(",", ".").replace(/[^0-9.\-]/g,""));
      return Number.isFinite(n) ? n : NaN;
    }
    function fmtMoney(n){
      try{
        return new Intl.NumberFormat(window.CATALOG_CONFIG.locale,{style:"currency",currency:window.CATALOG_CONFIG.currency,maximumFractionDigits:2}).format(n);
      }catch(e){
        return (Number.isFinite(n)? n.toFixed(2) : "—") + " " + window.CATALOG_CONFIG.currency;
      }
    }

    function totalQty(){
      let n=0;
      for(const k in cartState){
        const q = Math.floor(toNumber(cartState[k])||0);
        if(q>0) n+=q;
      }
      return n;
    }

    function resolveProduct(uid){
      // si catalogue chargé: window.__productByUid = Map(uid -> row)
      try{
        const m = window.__productByUid;
        if(m && typeof m.get === "function") return m.get(uid) || null;
      }catch(e){}
      return null;
    }

    function getRowPrice(row){
      const mode = window.CATALOG_CONFIG.priceMode || "inc";
      const key = (mode==="inc") ? "SalePriceVatIncluded" : "SalePriceVatExcluded";
      const v = row?.[key];
      const n = toNumber(v);
      return Number.isFinite(n) ? n : NaN;
    }

    function imgUrl(uid){
      const base = window.CATALOG_CONFIG.imagesBase;
      return base ? (base + "/" + encodeURIComponent(uid) + ".png") : "";
    }

    function updateBadge(){
      const n = totalQty();
      if(badge){
        badge.textContent = String(n);
        badge.classList.toggle("bg-danger", n>0);
        badge.classList.toggle("bg-secondary", n===0);
      }
    }

    async function syncState(force=false){
      const now = Date.now();
      if(!force && (now - lastSync) < 800) return; // anti spam
      lastSync = now;

      const res = await fetch(E.state, { credentials:"same-origin" });
      if(!res.ok) return;
      const data = await res.json().catch(()=>null);
      if(!data?.ok) return;

      cartState = data.cart || {};
      updateBadge();
      renderOffcanvas();
    }

    async function setQty(uid, qty){
      const res = await fetch(E.set, {
        method:"POST",
        credentials:"same-origin",
        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8", "X-Requested-With":"XMLHttpRequest" },
        body: new URLSearchParams({ id: uid, qty: String(qty) })
      });
      const data = await res.json().catch(()=>null);
      if(!res.ok || !data?.ok) return false;

      cartState = data.cart || {};
      updateBadge();
      renderOffcanvas();
      return true;
    }

    async function remove(uid){
      const res = await fetch(E.remove, {
        method:"POST",
        credentials:"same-origin",
        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8", "X-Requested-With":"XMLHttpRequest" },
        body: new URLSearchParams({ id: uid })
      });
      const data = await res.json().catch(()=>null);
      if(!res.ok || !data?.ok) return false;

      cartState = data.cart || {};
      updateBadge();
      renderOffcanvas();
      return true;
    }

    async function clear(){
      const res = await fetch(E.clear, {
        method:"POST",
        credentials:"same-origin",
        headers: { "X-Requested-With":"XMLHttpRequest", "Accept":"application/json" }
      });
      const data = await res.json().catch(()=>null);
      if(!res.ok || !data?.ok) return false;

      cartState = {};
      updateBadge();
      renderOffcanvas();
      return true;
    }

    function renderOffcanvas(){
      if(!listEl || !emptyEl || !totalEl) return;

      listEl.innerHTML = "";
      totalEl.textContent = "—";

      const keys = Object.keys(cartState).filter(k => (toNumber(cartState[k])||0) > 0);
      const has = keys.length > 0;

      emptyEl.classList.toggle("d-none", has);
      if(!has) return;

      let totalVal = 0;

      for(const uid of keys.sort((a,b)=>a.localeCompare(b,"fr"))){
        const qty = Math.floor(toNumber(cartState[uid])||0);
        const row = resolveProduct(uid);

        const title = row?.DesComClear || row?.Designation || uid;
        const brand = row?.xx_Marque || "";
        const price = row ? getRowPrice(row) : NaN;

        if(Number.isFinite(price)) totalVal += price * qty;

        const div = document.createElement("div");
        div.className = "cart-item";

        div.innerHTML = `
          <div class="cart-thumb">
            <img src="${imgUrl(uid)}" alt=""
              onerror="this.onerror=null;this.src='data:image/svg+xml;utf8,${encodeURIComponent(`<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120'><rect width='100%' height='100%' fill='%23f1f3f5'/><text x='50%' y='52%' text-anchor='middle' fill='%236c757d' font-family='Arial' font-size='14'>No image</text></svg>`)}';">
          </div>
          <div class="cart-meta">
            <div class="cart-title text-truncate">${String(title).replaceAll("<","&lt;").replaceAll(">","&gt;")}</div>
            <div class="cart-sub">${brand ? (brand + " • ") : ""}UID: ${uid}</div>
            <div class="cart-sub">${Number.isFinite(price) ? ("PU: " + fmtMoney(price)) : ""}</div>
          </div>
          <div class="d-flex flex-column align-items-end gap-2">
            <div class="qty-ctrl">
              <button class="btn btn-outline-secondary btn-sm" data-dec="${uid}" type="button">-</button>
              <input class="form-control form-control-sm" data-qty="${uid}" type="number" min="1" value="${qty}">
              <button class="btn btn-outline-secondary btn-sm" data-inc="${uid}" type="button">+</button>
            </div>
            <button class="btn btn-outline-danger btn-sm" data-rm="${uid}" type="button">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
        `;

        listEl.appendChild(div);
      }

      if(Number.isFinite(totalVal)) totalEl.textContent = fmtMoney(totalVal);
    }

    // events
    if(listEl){
      listEl.addEventListener("click", async (e)=>{
        const inc = e.target.closest("[data-inc]")?.getAttribute("data-inc");
        const dec = e.target.closest("[data-dec]")?.getAttribute("data-dec");
        const rm  = e.target.closest("[data-rm]")?.getAttribute("data-rm");

        if(inc){
          const q = Math.floor(toNumber(cartState[inc])||0) + 1;
          await setQty(inc, q);
        }
        if(dec){
          const q = Math.max(1, Math.floor(toNumber(cartState[dec])||1) - 1);
          await setQty(dec, q);
        }
        if(rm){
          await remove(rm);
        }
      });

      listEl.addEventListener("change", async (e)=>{
        const inp = e.target.closest("[data-qty]");
        if(!inp) return;
        const uid = inp.getAttribute("data-qty");
        const q = Math.max(1, Math.floor(toNumber(inp.value)||1));
        await setQty(uid, q);
      });
    }

    if(btnClear){
      btnClear.addEventListener("click", async ()=>{ await clear(); });
    }

    // sync on load
    document.addEventListener("DOMContentLoaded", ()=>{ syncState(true).catch(()=>{}); });

    // sync before open
    document.addEventListener("show.bs.offcanvas", (e)=>{
      if(e.target && e.target.id === "cartCanvas"){
        syncState(true).catch(()=>{});
      }
    });

    // expose helpers for catalogue/cart page
    window.CartUI = {
      sync: ()=>syncState(true),
      setQty,
      remove,
      clear,
      getState: ()=>cartState,
      setPriceMode: (m)=>{ window.CATALOG_CONFIG.priceMode = m; renderOffcanvas(); }
    };
  })();
</script>

