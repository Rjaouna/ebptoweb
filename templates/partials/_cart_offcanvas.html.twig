{# templates/partials/_cart_offcanvas.html.twig #}
<div class="offcanvas offcanvas-end" tabindex="-1" id="cartCanvas">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title"><i class="bi bi-cart3 me-2"></i>Panier</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>

  <div class="offcanvas-body">
    <div id="cartEmpty" class="text-center text-muted py-4">
      Votre panier est vide.
      <div class="small mt-2">Ajoutez des articles depuis le catalogue.</div>
    </div>

    <div class="d-grid gap-2" id="cartSummary"></div>

    <div class="d-flex gap-2 mt-3">
      <button class="btn btn-outline-danger w-100" id="btnCartClear" type="button">
        <i class="bi bi-trash"></i> Vider
      </button>
      <a class="btn btn-primary w-100" href="{{ path('cart_index') }}">
        <i class="bi bi-bag-check"></i> Commander
      </a>
    </div>

    {# ✅ Total masqué par défaut. Catalogue l’affichera si prix dispo #}
    <div id="cartTotalWrap" class="mt-3 p-3 border rounded bg-white d-none">
      <div class="d-flex align-items-center justify-content-between">
        <div class="fw-semibold">Total estimé</div>
        <div class="fw-semibold" id="cartTotal">—</div>
      </div>
      <div class="small text-muted mt-1">Prix/total disponibles sur la page Catalogue.</div>
    </div>
  </div>
</div>
