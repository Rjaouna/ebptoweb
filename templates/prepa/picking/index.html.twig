{% extends 'base.html.twig' %}

{% block title %}Picking{% endblock %}

{% block body %}
<div class="container py-4">

  <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div class="min-w-0">
      <div class="d-flex align-items-center gap-2">
        <div class="orders-icon"><i class="bi bi-box-seam"></i></div>
        <div class="min-w-0">
          <h1 class="h4 mb-1 fw-black text-truncate">Picking</h1>
          <div class="text-muted small text-truncate">Commandes en préparation</div>
        </div>
      </div>
    </div>

    <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis border border-primary-subtle px-3 py-2">
      {{ orders|length }} commande(s)
    </span>
  </div>

  <form class="card border-0 shadow-sm rounded-4 overflow-hidden mb-3" method="get">
    <div class="card-body p-3 p-lg-4">
      <div class="row g-2 align-items-center">
        <div class="col-12 col-lg-8">
          <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input class="form-control" name="q" value="{{ q|default('') }}" placeholder="Recherche: nom client / email / référence…" autocomplete="off">
          </div>
        </div>
        <div class="col-12 col-lg-4 d-flex justify-content-lg-end">
          <button class="btn btn-primary rounded-pill" type="submit">
            <i class="bi bi-funnel me-2"></i>Filtrer
          </button>
        </div>
      </div>
    </div>
  </form>

  {% if orders is empty %}
    <div class="alert alert-light border rounded-4">
      <i class="bi bi-inbox me-2 text-secondary"></i>Aucune commande en préparation.
    </div>
  {% else %}
    <div class="d-grid gap-2">
      {% for o in orders %}
        <a href="{{ path('prepa_picking_show', {id: o.id}) }}"
           class="text-decoration-none text-body">
          <div class="order-row">
            <div class="d-flex align-items-start justify-content-between gap-3">
              <div class="min-w-0">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                  <div class="order-ref">{{ o.reference ?? ('CMD-' ~ o.id) }}</div>

                  <span class="order-status">
                    {{ statusLabels[o.status]|default(o.status) }}
                  </span>

                  <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">
                    {{ o.commandeLignes|length }} article(s)
                  </span>
                </div>

                <div class="order-meta mt-1 text-truncate">
                  <i class="bi bi-person me-1"></i>{{ o.customerName ?? (o.user ? o.user.email : '—') }}
                  &nbsp;•&nbsp;
                  <i class="bi bi-clock me-1"></i>{{ o.createdAt ? o.createdAt|date('d/m/Y H:i') : '—' }}
                </div>
              </div>

              <div class="text-end">
                <div class="fw-black text-nowrap">
                  {{ o.totalTtc is not null ? (o.totalTtc|number_format(2, ',', ' ') ~ ' MAD') : '—' }}
                </div>
                <div class="small text-muted">TTC</div>
              </div>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  {% endif %}

</div>

<style>
  .fw-black{ font-weight:900; }
  .orders-icon{
    width:44px;height:44px;border-radius:14px;display:grid;place-items:center;
    background: rgba(var(--bs-primary-rgb), .12);
    border: 1px solid rgba(var(--bs-primary-rgb), .18);
    color: var(--bs-primary);
    flex:0 0 auto;
  }
  .order-row{
    border: 1px solid rgba(0,0,0,.06);
    background:#fff;border-radius:18px;padding:14px 14px;
    transition: transform .12s ease, box-shadow .12s ease;
  }
  .order-row:hover{ transform: translateY(-1px); box-shadow: 0 .4rem 1rem rgba(0,0,0,.06); }
  .order-ref{ font-weight:900; }
  .order-meta{ color:#6c757d; font-size:.86rem; }
  .order-status{
    font-size:.75rem;border-radius:999px;padding:.25rem .55rem;
    border:1px solid rgba(0,0,0,.08);
    background: rgba(108,117,125,.08);
    color:#495057; white-space:nowrap;
  }
</style>
{% endblock %}
