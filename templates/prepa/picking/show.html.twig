{% extends 'base.html.twig' %}

{% block title %}Picking • Détails{% endblock %}

{% block body %}
{% set CUR = 'MAD' %}
{% set ref = order.reference ?? ('CMD-' ~ order.id) %}
{% set customer = order.customerName ?? (order.user ? order.user.email : '—') %}
{% set created = order.createdAt ? order.createdAt|date('d/m/Y H:i') : '—' %}
{% set statusLabel = statusLabels[order.status]|default(order.status) %}

{# Progress: lignes complètes = total - missingLines #}
{% set completeLines = (totalLines - missingLines) %}
{% set progress = totalLines > 0 ? ((completeLines * 100) / totalLines) : 0 %}

<div class="container py-4">

  {# Header #}
  <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
    <div class="min-w-0">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <a href="{{ path('prepa_picking_index') }}" class="btn btn-sm btn-outline-danger rounded-pill">
          <i class="bi bi-arrow-left me-1"></i>Retour
        </a>

        <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis border border-primary-subtle px-3 py-2">
          {{ ref }}
        </span>

        <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle px-3 py-2">
          {{ statusLabel }}
        </span>

        {% if missingLines > 0 %}
          <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle px-3 py-2">
            <i class="bi bi-exclamation-triangle me-1"></i>{{ missingLines }} ligne(s) incomplète(s)
          </span>
        {% else %}
          <span class="badge rounded-pill bg-success-subtle text-success-emphasis border border-success-subtle px-3 py-2">
            <i class="bi bi-check2-circle me-1"></i>Tout est OK
          </span>
        {% endif %}
      </div>

      <div class="text-muted small mt-2 text-truncate">
        <i class="bi bi-person me-1"></i>{{ customer }}
        <span class="mx-2">•</span>
        <i class="bi bi-clock me-1"></i>{{ created }}
        <span class="mx-2">•</span>
        <i class="bi bi-list-check me-1"></i>{{ totalLines }} ligne(s)
      </div>
    </div>

    <div class="text-end">
      <div class="text-muted small">Total TTC</div>
      <div class="h4 fw-black mb-0">
        {{ order.totalTtc is not null ? (order.totalTtc|number_format(2, ',', ' ') ~ ' ' ~ CUR) : '—' }}
      </div>
      <div class="text-muted small">
        HT :
        <span class="fw-semibold">
          {{ order.totalHt is not null ? (order.totalHt|number_format(2, ',', ' ') ~ ' ' ~ CUR) : '—' }}
        </span>
      </div>
    </div>
  </div>

  <div class="row g-3">
    {# Col gauche: lignes #}
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="p-3 p-lg-4"
             style="background: linear-gradient(180deg, rgba(var(--bs-primary-rgb), .10), rgba(255,255,255,0));">

          <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
            <div class="fw-black">
              <i class="bi bi-bag-check me-2 text-primary"></i>Liste à picker
            </div>

            <div class="d-flex align-items-center gap-2 flex-wrap">
              <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle px-3 py-2">
                <i class="bi bi-check2 me-1"></i><span id="badgeComplete">{{ completeLines }}</span>/{{ totalLines }} complète(s)
              </span>

              <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle px-3 py-2">
                <i class="bi bi-exclamation-triangle me-1"></i>
                <span id="badgeMissingLines">{{ missingLines }}</span> ligne(s) incomplète(s)
                {% if missingQtyTotal > 0 %}
                  • manque <span id="badgeMissingQty">{{ missingQtyTotal }}</span>
                {% else %}
                  • manque <span id="badgeMissingQty">0</span>
                {% endif %}
              </span>
            </div>
          </div>

          <div class="mt-3">
            <div class="progress rounded-pill" style="height: 12px;">
              <div id="progressBar"
                   class="progress-bar"
                   role="progressbar"
                   style="width: {{ progress|round(0, 'floor') }}%;"
                   aria-valuenow="{{ progress|round(0, 'floor') }}"
                   aria-valuemin="0"
                   aria-valuemax="100"></div>
            </div>
            <div class="small text-muted mt-2">
              Avancement: <span id="progressText">{{ progress|round(0, 'floor') }}</span>%
            </div>
          </div>

          {% if lines is empty %}
            <div class="alert alert-light border rounded-4 mt-3 mb-0">
              <i class="bi bi-inbox me-2 text-secondary"></i>Aucune ligne.
            </div>
          {% else %}
            <div class="d-grid gap-2 mt-3" id="linesWrap">
              {% for l in lines %}
                {% set isComplete = (l.missing == 0) %}
                <div class="pick-line {{ isComplete ? 'is-ok' : 'is-miss' }}"
                     data-line-id="{{ l.id }}"
                     data-need="{{ l.need }}"
                     data-picked="{{ l.picked }}"
                     data-name="{{ l.name|e('html_attr') }}"
                     data-ref="{{ (l.ref ?? '')|e('html_attr') }}">

                  <div class="d-flex align-items-start justify-content-between gap-3">
                    <div class="min-w-0">
                      <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="fw-black">
                          {{ l.name }}
                        </div>

                        <span class="badge rounded-pill bg-light text-secondary border px-3 py-2">
                          Article #{{ l.id }}
                        </span>

                        {% if l.ref %}
                          <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle px-3 py-2">
                            Réf: {{ l.ref }}
                          </span>
                        {% endif %}
                      </div>

                      <div class="d-flex gap-2 flex-wrap mt-2">
                        <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis border border-primary-subtle px-3 py-2">
                          À prendre: <b class="ms-1">{{ l.need }}</b>
                        </span>

                        <span class="badge rounded-pill bg-success-subtle text-success-emphasis border border-success-subtle px-3 py-2">
                          Pris: <b class="ms-1 pickedVal">{{ l.picked }}</b>
                        </span>

                        <span class="badge rounded-pill {{ isComplete ? 'bg-success-subtle text-success-emphasis border-success-subtle' : 'bg-warning-subtle text-warning-emphasis border-warning-subtle' }} border px-3 py-2">
                          Manque: <b class="ms-1 missingVal">{{ l.missing }}</b>
                        </span>
                      </div>
                    </div>

                    <div class="text-end">
                      <button type="button"
                              class="btn btn-outline-secondary btn-sm rounded-pill btnPick"
                              data-line="{{ l.id }}">
                        <i class="bi bi-clipboard-check me-1"></i>{{ isComplete ? 'Modifier' : 'Valider' }}
                      </button>
                    </div>
                  </div>

                </div>
              {% endfor %}
            </div>
          {% endif %}

        </div>
      </div>
    </div>

    {# Col droite: actions #}
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 90px;">
        <div class="card-body p-3 p-lg-4">
          <div class="fw-black mb-2">
            <i class="bi bi-lightning-charge me-2 text-primary"></i>Clôture
          </div>

          <div class="text-muted small">
            Tu peux clôturer même s’il manque des articles, mais une confirmation sera demandée.
          </div>

          <hr class="my-3">

          <button class="btn btn-primary w-100 rounded-pill" id="btnFinalize" type="button">
            <i class="bi bi-check2-circle me-2"></i>Valider le picking
          </button>

          <div class="small text-muted mt-3">
            La commande passera automatiquement au statut suivant (READY) et disparaîtra de la liste “en préparation”.
          </div>

          {% if order.note %}
            <hr class="my-3">
            <div class="small text-muted">Note</div>
            <div class="p-2 rounded-3 border bg-light small" style="white-space: pre-line;">{{ order.note }}</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{# Modal Pick line #}
<div class="modal fade" id="pickModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 overflow-hidden">
      <div class="p-3 p-lg-4" style="background: linear-gradient(180deg, rgba(var(--bs-primary-rgb), .10), rgba(255,255,255,0));">
        <div class="d-flex align-items-start justify-content-between gap-3">
          <div class="min-w-0">
            <div class="fw-black mb-1">Valider prélèvement</div>
            <div class="text-muted small" id="pickSub">—</div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="mt-3">
          <label class="form-label fw-semibold">Quantité prélevée</label>
          <input type="number" class="form-control form-control-lg rounded-4" id="pickQty" min="0" step="1">
          <div class="text-muted small mt-2" id="pickHint">—</div>
        </div>

        <div class="d-flex gap-2 mt-3">
          <button class="btn btn-light rounded-pill" type="button" id="btnPickZero">
            <i class="bi bi-x-circle me-1"></i>0
          </button>
          <button class="btn btn-light rounded-pill" type="button" id="btnPickMax">
            <i class="bi bi-check2 me-1"></i>Qté demandée
          </button>
          <button class="btn btn-primary rounded-pill ms-auto" type="button" id="btnPickSave">
            <i class="bi bi-save me-1"></i>Enregistrer
          </button>
        </div>

        <div class="text-muted small mt-3">
          Astuce: si tu trouves 4 au lieu de 5, mets 4. Le système gardera un badge “manque”.
        </div>
      </div>
    </div>
  </div>
</div>

{# Modal confirm missing on finalize #}
<div class="modal fade" id="missingModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 overflow-hidden">
      <div class="p-3 p-lg-4" style="background: linear-gradient(180deg, rgba(255,193,7,.18), rgba(255,255,255,0));">
        <div class="d-flex align-items-start justify-content-between gap-3">
          <div class="min-w-0">
            <div class="fw-black mb-1">Articles manquants</div>
            <div class="text-muted small">Tu peux quand même clôturer, mais la commande sera marquée comme incomplète.</div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="mt-3 d-grid gap-2" id="missingList"></div>

        <div class="d-flex gap-2 mt-3">
          <button class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal" type="button">
            Annuler
          </button>
          <button class="btn btn-warning rounded-pill ms-auto" type="button" id="btnForceFinalize">
            <i class="bi bi-exclamation-triangle me-1"></i>Clôturer quand même
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.PREPA_PICKING = {
    lineUrlTpl: "{{ path('prepa_picking_ajax_line', {id: order.id, lineId: 999999})|replace({'999999':'__LINE__'}) }}",
    finalizeUrl: "{{ path('prepa_picking_ajax_finalize', {id: order.id}) }}",
    redirectUrl: "{{ path('prepa_picking_index') }}",
    csrfLine: "{{ csrfLine }}",
    csrfFinalize: "{{ csrfFinalize }}",
    totalLines: {{ totalLines|default(0) }},
  };
</script>

<style>
  .fw-black{ font-weight:900; }

  .pick-line{
    border: 1px solid rgba(0,0,0,.06);
    background:#fff;
    border-radius:18px;
    padding:14px 14px;
    transition: transform .12s ease, box-shadow .12s ease;
  }
  .pick-line:hover{ transform: translateY(-1px); box-shadow: 0 .4rem 1rem rgba(0,0,0,.06); }
  .pick-line.is-ok{ outline: 2px solid rgba(25,135,84,.12); }
  .pick-line.is-miss{ outline: 2px solid rgba(255,193,7,.16); }

  .missing-item{
    border-radius:16px;
    border:1px solid rgba(0,0,0,.06);
    background:#fff;
    padding:12px 14px;
  }
</style>
{% endblock %}

{% block javascripts %}
<script>
(function(){
  const CFG = window.PREPA_PICKING || {};
  const modalEl = document.getElementById("pickModal");
  const modal = modalEl ? bootstrap.Modal.getOrCreateInstance(modalEl) : null;

  const missingModalEl = document.getElementById("missingModal");
  const missingModal = missingModalEl ? bootstrap.Modal.getOrCreateInstance(missingModalEl) : null;

  const pickSub = document.getElementById("pickSub");
  const pickQty = document.getElementById("pickQty");
  const pickHint = document.getElementById("pickHint");
  const btnPickSave = document.getElementById("btnPickSave");
  const btnPickZero = document.getElementById("btnPickZero");
  const btnPickMax = document.getElementById("btnPickMax");

  const badgeMissingLines = document.getElementById("badgeMissingLines");
  const badgeMissingQty = document.getElementById("badgeMissingQty");
  const badgeComplete = document.getElementById("badgeComplete");
  const progressBar = document.getElementById("progressBar");
  const progressText = document.getElementById("progressText");

  const btnFinalize = document.getElementById("btnFinalize");
  const missingList = document.getElementById("missingList");
  const btnForceFinalize = document.getElementById("btnForceFinalize");

  let currentLineId = null;
  let currentNeed = 0;

  function esc(s){
    return String(s ?? "")
      .replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;");
  }

  function lineUrl(lineId){
    return (CFG.lineUrlTpl || "").replace("__LINE__", String(lineId));
  }

  function setProgress(missingLines){
    const total = Number(CFG.totalLines || 0);
    const complete = Math.max(0, total - Number(missingLines || 0));
    const pct = total > 0 ? Math.floor((complete * 100) / total) : 0;

    if (badgeComplete) badgeComplete.textContent = String(complete);
    if (progressBar) progressBar.style.width = pct + "%";
    if (progressText) progressText.textContent = String(pct);
  }

  function updateLineUI(lineId, picked){
    const row = document.querySelector(`.pick-line[data-line-id="${lineId}"]`);
    if(!row) return;

    const need = parseInt(row.getAttribute("data-need") || "0", 10) || 0;
    const missing = Math.max(0, need - picked);

    row.setAttribute("data-picked", String(picked));

    const pickedEl = row.querySelector(".pickedVal");
    const missingEl = row.querySelector(".missingVal");
    if (pickedEl) pickedEl.textContent = String(picked);
    if (missingEl) missingEl.textContent = String(missing);

    row.classList.toggle("is-ok", missing === 0);
    row.classList.toggle("is-miss", missing !== 0);

    const btn = row.querySelector(".btnPick");
    if(btn) btn.innerHTML = `<i class="bi bi-clipboard-check me-1"></i>${missing === 0 ? 'Modifier' : 'Valider'}`;
  }

  async function saveLine(lineId, qty){
    const body = new URLSearchParams();
    body.set("qty", String(qty));
    body.set("_token", CFG.csrfLine || "");

    const res = await fetch(lineUrl(lineId), {
      method: "POST",
      credentials: "same-origin",
      headers: {
        "Content-Type":"application/x-www-form-urlencoded; charset=UTF-8",
        "X-Requested-With":"XMLHttpRequest",
        "Accept":"application/json",
        "X-CSRF-TOKEN": CFG.csrfLine || ""
      },
      body
    });

    const data = await res.json().catch(()=>null);
    if(!res.ok || !data?.ok){
      alert(data?.message || ("Erreur HTTP " + res.status));
      return null;
    }
    return data;
  }

  document.addEventListener("click", (e) => {
    const btn = e.target.closest(".btnPick");
    if(!btn) return;

    const lineId = btn.getAttribute("data-line");
    const row = document.querySelector(`.pick-line[data-line-id="${lineId}"]`);
    if(!row) return;

    currentLineId = parseInt(lineId, 10);
    currentNeed = parseInt(row.getAttribute("data-need") || "0", 10) || 0;

    const name = row.getAttribute("data-name") || "";
    const ref = row.getAttribute("data-ref") || "";
    const picked = parseInt(row.getAttribute("data-picked") || "0", 10) || 0;

    if(pickSub) pickSub.textContent = `${name}${ref ? " • Réf: " + ref : ""} • Article #${lineId}`;
    if(pickQty){
      pickQty.value = String(picked > 0 ? picked : currentNeed);
      pickQty.min = "0";
      pickQty.max = String(currentNeed);
    }
    if(pickHint) pickHint.textContent = `Demandé: ${currentNeed} • Déjà pris: ${picked}`;

    modal?.show();
  });

  btnPickZero?.addEventListener("click", () => { if(pickQty) pickQty.value = "0"; });
  btnPickMax?.addEventListener("click", () => { if(pickQty) pickQty.value = String(currentNeed); });

  btnPickSave?.addEventListener("click", async () => {
    if(currentLineId === null) return;

    const qty = Math.max(0, Math.min(currentNeed, parseInt(pickQty?.value || "0", 10) || 0));
    btnPickSave.disabled = true;

    const data = await saveLine(currentLineId, qty);
    btnPickSave.disabled = false;

    if(!data) return;

    updateLineUI(currentLineId, qty);

    if(badgeMissingLines) badgeMissingLines.textContent = String(data.missingLines ?? 0);
    if(badgeMissingQty) badgeMissingQty.textContent = String(data.missingQtyTotal ?? 0);
    setProgress(data.missingLines ?? 0);

    modal?.hide();
  });

  async function finalize(force){
    const body = new URLSearchParams();
    body.set("_token", CFG.csrfFinalize || "");
    body.set("force", force ? "1" : "0");

    const res = await fetch(CFG.finalizeUrl, {
      method:"POST",
      credentials:"same-origin",
      headers:{
        "Content-Type":"application/x-www-form-urlencoded; charset=UTF-8",
        "X-Requested-With":"XMLHttpRequest",
        "Accept":"application/json",
        "X-CSRF-TOKEN": CFG.csrfFinalize || ""
      },
      body
    });

    const data = await res.json().catch(()=>null);
    return { res, data };
  }

  btnFinalize?.addEventListener("click", async () => {
    btnFinalize.disabled = true;

    const { res, data } = await finalize(false);
    btnFinalize.disabled = false;

    if(res.ok && data?.ok){
      window.location.href = CFG.redirectUrl || "/";
      return;
    }

    // manque -> modal confirm
    if(res.status === 409 && data?.code === "MISSING_ITEMS"){
      if(missingList){
        missingList.innerHTML = "";
        for(const m of (data.missing || [])){
          const div = document.createElement("div");
          div.className = "missing-item";
          div.innerHTML = `
            <div class="fw-black">${esc(m.name || "Article")}</div>
            <div class="text-muted small">
              ${m.ref ? "Réf: " + esc(m.ref) + " • " : ""}Ligne #${esc(m.lineId)} • Manque: <b>${esc(m.missing)}</b>
            </div>
          `;
          missingList.appendChild(div);
        }
      }
      missingModal?.show();
      return;
    }

    alert(data?.message || "Erreur lors de la clôture.");
  });

  btnForceFinalize?.addEventListener("click", async () => {
    btnForceFinalize.disabled = true;

    const { res, data } = await finalize(true);
    btnForceFinalize.disabled = false;

    if(res.ok && data?.ok){
      missingModal?.hide();
      window.location.href = CFG.redirectUrl || "/";
      return;
    }

    alert(data?.message || "Erreur lors de la clôture.");
  });

})();
</script>
{% endblock %}
