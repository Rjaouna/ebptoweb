{# templates/home/sections/_categories.html.twig #}
<section id="categories" class="py-4 py-lg-5 bg-body-tertiary">
	<div class="container">
		<div class="mb-3">
			<h2 class="h3 fw-bold mb-1">Catégories</h2>
			<div class="text-body-secondary">Accès complet après connexion.</div>
		</div>

		{% set categories = [
            {'name':'Freinage', 'desc':'Plaquettes, disques, étriers, liquide', 'emoji':'🛑'},
            {'name':'Filtration', 'desc':'Huile, air, carburant, habitacle', 'emoji':'🧼'},
            {'name':'Batterie / Électricité', 'desc':'Batteries, alternateurs, démarreurs', 'emoji':'🔋'},
            {'name':'Suspension / Direction', 'desc':'Rotules, triangles, amortisseurs', 'emoji':'🛞'},
            {'name':'Embrayage / Transmission', 'desc':'Kits, cardans, supports', 'emoji':'⚙️'},
            {'name':'Moteur / Capteurs', 'desc':'Capteurs, courroies, pompes', 'emoji':'🧠'},
            {'name':'Refroidissement / Clim', 'desc':'Radiateurs, compresseurs, durites', 'emoji':'❄️'},
            {'name':'Huiles & Consommables', 'desc':'Huiles, additifs, accessoires', 'emoji':'🛢️'}
        ] %}

		<div class="row g-3">
			{% for c in categories %}
				<div class="col-md-6 col-lg-3">
					<a class="text-decoration-none" href="#" {% if not app.user %} data-bs-toggle="modal" data-bs-target="#loginGateModal" {% endif %}>
						<div class="card h-100 border-0 shadow-sm rounded-4">
							<div class="card-body">
								<div class="d-flex align-items-start gap-2">
									<div class="rounded-3 bg-white border d-flex align-items-center justify-content-center" style="width:44px;height:44px;">
										{{ c.emoji }}
									</div>
									<div>
										<div class="fw-bold d-flex align-items-center gap-2">
											{{ c.name }}
											{% if not app.user %}
												<span class="badge rounded-pill text-bg-light border">Connexion</span>
											{% endif %}
										</div>
										<div class="small text-body-secondary">{{ c.desc }}</div>
									</div>
								</div>
							</div>
						</div>
					</a>
				</div>
			{% endfor %}
		</div>
	</div>
</section>

