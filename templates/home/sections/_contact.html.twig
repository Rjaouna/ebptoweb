{# templates/home/sections/_contact.html.twig #}
<section id="contact" class="py-4 py-lg-5">
	<div class="container">
		<div class="card border-0 shadow-sm rounded-4">
			<div class="card-body p-4">
				<div class="row g-3 align-items-center">
					<div class="col-lg-8">
						<h2 class="h4 fw-bold mb-1">Contact & retrait</h2>
						<div class="text-body-secondary mb-2">
							{{ address|default('Adresse du magasin, Quartier, Ville') }}
						</div>
						<div class="d-flex flex-wrap gap-2">
							<span class="badge rounded-pill text-bg-light border">📞
								{{ phone_display|default('+212 6 00 00 00 00') }}</span>
							<span class="badge rounded-pill text-bg-light border">🕒
								{{ opening_hours|default('Lun–Sam 09:00–19:00') }}</span>
							<span class="badge rounded-pill text-bg-light border">🚚 Livraison disponible</span>
						</div>
					</div>

					<div class="col-lg-4 text-lg-end">
						<a class="btn btn-primary btn-lg rounded-pill fw-semibold px-4" href="#">WhatsApp</a>
						<a class="btn btn-outline-secondary btn-lg rounded-pill fw-semibold px-4 mt-2 mt-lg-0" href="#">
							Appeler
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

