{# templates/home/sections/_topbar.html.twig #}
<div class="bg-body-tertiary border-bottom">
	<div class="container py-2">
		<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 small">
			<div class="d-flex flex-wrap align-items-center gap-3 text-body-secondary">
				<span>📍
					{{ public_city|default('Votre ville') }}</span>
				<span>🕒
					{{ opening_hours|default('Lun–Sam 09:00–19:00') }}</span>
				<span>🚚 Livraison & retrait</span>
			</div>

			<div class="d-flex flex-wrap align-items-center gap-3">
				<a class="text-decoration-none" href="#">
					📞
					<strong>{{ phone_display|default('+212 6 00 00 00 00') }}</strong>
				</a>
				<a class="text-decoration-none" href="#">💬 WhatsApp</a>
			</div>
		</div>
	</div>
</div>

