{# templates/home/sections/_quote.html.twig #}
<section id="devis" class="py-4 py-lg-5 bg-body-tertiary">
	<div class="container">
		<div class="row g-3 align-items-stretch">
			<div class="col-lg-7">
				<div class="card border-0 shadow-sm rounded-4 h-100">
					<div class="card-body p-4">
						<h2 class="h4 fw-bold mb-2">Devis express (sans compte)</h2>
						<p class="text-body-secondary mb-4">
							Donnez une référence, immatriculation ou VIN — réponse rapide.
						</p>

						<form action="#" method="post" class="row g-2">
							<div class="col-12">
								<input class="form-control form-control-lg rounded-pill" name="query" placeholder="Référence / Immatriculation / VIN" required>
							</div>
							<div class="col-md-6">
								<input class="form-control rounded-pill" name="fullname" placeholder="Nom complet" required>
							</div>
							<div class="col-md-6">
								<input class="form-control rounded-pill" name="phone" placeholder="Téléphone / WhatsApp" required>
							</div>
							<div class="col-12">
								<input class="form-control rounded-pill" name="email" type="email" placeholder="Email (optionnel)">
							</div>
							<div class="col-12">
								<textarea class="form-control rounded-4" name="details" rows="4" placeholder="Détails (marque/modèle/année, quantité, urgence…)"></textarea>
							</div>
							<div class="col-12 d-flex flex-wrap gap-2 mt-2">
								<button class="btn btn-primary btn-lg rounded-pill fw-semibold px-4" type="submit">
									Envoyer ma demande
								</button>
								{% if not app.user %}
									<a class="btn btn-outline-secondary btn-lg rounded-pill fw-semibold px-4" href="#">
										Créer un compte
									</a>
								{% endif %}
							</div>

							<div class="small text-body-secondary mt-2">
								🔒 Prix & stock détaillés : visibles dans l’espace client.
							</div>
						</form>
					</div>
				</div>
			</div>

			<div class="col-lg-5">
				<div class="card border-0 shadow-sm rounded-4 h-100">
					<div class="card-body p-4">
						<h3 class="h5 fw-bold mb-3">Accès client = gain de temps</h3>

						<ul class="list-unstyled vstack gap-2 mb-4">
							<li>✅
								<strong>Prix</strong>
								selon profil</li>
							<li>✅
								<strong>Disponibilité</strong>
								& délais</li>
							<li>✅
								<strong>Équivalences</strong>
								& alternatives</li>
							<li>✅
								<strong>Historique</strong>
								commandes & factures</li>
							<li>✅
								<strong>Commande rapide</strong>
								en quelques clics</li>
						</ul>

						{% if app.user %}
							<a class="btn btn-primary btn-lg rounded-pill fw-semibold w-100" href="#">
								Accéder au catalogue
							</a>
						{% else %}
							<a class="btn btn-primary btn-lg rounded-pill fw-semibold w-100" href="#">
								Créer mon compte
							</a>
							<a class="btn btn-outline-secondary btn-lg rounded-pill fw-semibold w-100 mt-2" href="#">
								J’ai déjà un compte
							</a>
						{% endif %}
					</div>
				</div>
			</div>

		</div>
	</div>
</section>

