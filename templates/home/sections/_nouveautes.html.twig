{# =========================
   SECTION NOUVEAUTÉS (CSV local)
   Images: https://catalogue.3skpartsauto.com/export_images/{UniqueId}.png
   Dépendances: Bootstrap 5 + Bootstrap Icons
   Requiert: PapaParse (comme le catalogue) + CartUI global
   ========================= #}

<style>
  .new-box{
    border:1px solid rgba(15,23,42,.08);
    border-radius:22px;
    background:#fff;
    overflow:hidden;
  }
  .new-head{
    padding: clamp(1rem, 2vw, 1.4rem);
    border-bottom:1px solid rgba(15,23,42,.06);
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:1rem;
  }
  .new-title{
    margin:0;
    font-weight: 900;
    letter-spacing:-.02em;
    font-size: clamp(1.2rem, 2.1vw, 1.7rem);
  }
  .new-sub{ margin:.25rem 0 0; color:#6c757d; }

  .new-badge{
    font-size:.78rem;
    border-radius:999px;
    padding:.35rem .7rem;
    background: rgba(var(--bs-primary-rgb), .12);
    color: var(--bs-primary);
    border: 1px solid rgba(var(--bs-primary-rgb), .18);
    font-weight: 800;
    white-space: nowrap;
  }

  .new-grid{ padding: clamp(1rem, 2vw, 1.4rem); }

  .new-card{
    border:1px solid rgba(15,23,42,.08);
    border-radius:18px;
    overflow:hidden;
    background:#fff;
    height:100%;
    transition: transform .18s ease, box-shadow .18s ease;
    position: relative;
  }
  .new-card:hover{
    transform: translateY(-3px);
    box-shadow: 0 14px 34px rgba(2,6,23,.10);
  }

  /* Badge panier (comme catalogue) */
  .new-cart-pill{
    position:absolute;
    top:10px;
    right:10px;
    z-index: 3;
    display:inline-flex;
    align-items:center;
    gap:.35rem;
    padding:.3rem .55rem;
    border-radius:999px;
    background: rgba(255,255,255,.92);
    border:1px solid rgba(15,23,42,.10);
    box-shadow: 0 10px 25px rgba(2,6,23,.10);
    font-weight: 900;
    font-size: .78rem;
  }
  .new-cart-pill i{ color: var(--bs-primary); }
  .new-cart-pill.d-none{ display:none !important; }

  .new-thumb{
    padding: 10px;
    border-bottom: 1px solid rgba(15,23,42,.06);
    background: #fff;
  }
  .new-img{
    width:100%;
    height: 150px;
    object-fit: contain;
    background: #f8f9fa;
    border: 1px solid rgba(15,23,42,.08);
    border-radius: 14px;
    padding: 6px;
    display:block;
  }

  .new-body{ padding: .9rem; }
  .new-name{
    font-weight: 900;
    margin:0;
    font-size: .98rem;
    line-height:1.2;
  }
  .new-meta{
    color:#6c757d;
    font-size:.85rem;
    margin:.35rem 0 .6rem;
    min-height: 2.2em;
  }
  .new-price{ font-weight: 900; font-size: 1.02rem; }

  .new-chip{
    display:inline-flex;
    align-items:center;
    gap:.35rem;
    font-size:.78rem;
    padding:.25rem .55rem;
    border-radius:999px;
    border:1px solid rgba(25,135,84,.25);
    background: rgba(25,135,84,.08);
    color: #198754;
    font-weight: 800;
  }

  .new-actions{
    padding: .85rem .9rem;
    border-top: 1px solid rgba(15,23,42,.06);
    background: rgba(248,249,250,.55);
  }

  .new-actions .btn{ border-radius: 999px; font-weight: 900; }

  .new-skel{
    border:1px dashed rgba(15,23,42,.18);
    border-radius:18px;
    height: 290px;
    background: linear-gradient(90deg, rgba(2,6,23,.04), rgba(2,6,23,.02), rgba(2,6,23,.04));
    background-size: 220% 100%;
    animation: shimmer 1.2s infinite linear;
  }
  @keyframes shimmer{ from{background-position:0% 0} to{background-position:220% 0} }
</style>

{% set newDays = newDays|default(5) %}
{% set csvUrl = csvUrl|default(path('catalogue_csv')) %}
{% set imagesBase = imagesBase|default('https://catalogue.3skpartsauto.com/export_images') %}

<section class="container px-3 px-lg-4 my-4">
  <div class="new-box">
    <div class="new-head">
      <div>
        <h2 class="new-title"><i class="bi bi-stars me-2 text-primary"></i>Nouveautés</h2>
        <p class="new-sub mb-0">Uniquement les articles <strong>en stock</strong> ajoutés / mis à jour sur <strong>{{ newDays }}</strong> jours.</p>
      </div>

      <div class="d-flex align-items-center gap-2">
        <span class="new-badge">
          <i class="bi bi-clock-history me-1"></i>{{ newDays }} jours
        </span>
        <a href="{{ path('catalogue_new') }}" class="btn btn-sm btn-outline-primary rounded-pill px-3">
          Voir tout <i class="bi bi-arrow-right ms-1"></i>
        </a>
      </div>
    </div>

    <div class="new-grid">
      <div class="row g-3" id="newGrid">
        {% for i in 1..6 %}
          <div class="col-6 col-md-4 col-xl-2">
            <div class="new-skel"></div>
          </div>
        {% endfor %}
      </div>

      <div class="text-center mt-3 d-none" id="newEmpty">
        <div class="fw-bold">Aucune nouveauté en stock</div>
        <div class="text-muted small">Vérifie la date ExportStartedAt/sysModifiedDate et RealStock dans le CSV.</div>
      </div>
    </div>
  </div>
</section>

<script>
(function(){
  const CSV_URL = {{ csvUrl|json_encode|raw }};
  const IMAGES_BASE = {{ imagesBase|json_encode|raw }};
  const DAYS = {{ newDays }};
  const LIMIT = 6; // tu peux laisser 12, la grille reste en 6 colonnes sur xl

  const grid = document.getElementById('newGrid');
  const empty = document.getElementById('newEmpty');

  const CartUI = window.CartUI;

  const stripQuotes = (s) => {
    if (s === null || s === undefined) return "";
    s = String(s).trim();
    if (s.startsWith('"') && s.endsWith('"')) s = s.slice(1, -1);
    return s.trim();
  };

  function toNumber(v){
    if(v === null || v === undefined) return NaN;
    let s = String(v).trim();
    if(!s) return NaN;
    s = s.replace(/\s/g,"").replace(",", ".").replace(/[^0-9.\-]/g,"");
    const n = Number(s);
    return Number.isFinite(n) ? n : NaN;
  }

  function esc(s){
    return String(s ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m]));
  }

  function fmtMoney(val){
    const n = toNumber(val);
    if(!Number.isFinite(n)) return "—";
    try{
      return new Intl.NumberFormat("fr-FR", { style:"currency", currency:"", maximumFractionDigits: 2 }).format(n);
    }catch(_){
      return n.toFixed(2) + " MAD";
    }
  }

  function parseDateAny(s){
    if(!s) return null;
    let raw = stripQuotes(String(s));
    if(!raw) return null;

    // ISO-ish
    if (/^\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}/.test(raw)) raw = raw.replace(" ", "T");
    const d = new Date(raw);
    return isNaN(d.getTime()) ? null : d;
  }

  // ✅ image = {UniqueId}.png
  function imgUrl(uid){
    uid = stripQuotes(uid);
    if(!uid) return "";
    return IMAGES_BASE.replace(/\/$/,'') + "/" + encodeURIComponent(uid) + ".png";
  }

  // ✅ date nouveauté : ExportStartedAt (sinon sysModifiedDate, sinon sysCreatedDate)
  function rowDate(r){
    return parseDateAny(r.ExportStartedAt || r.sysModifiedDate || r.sysCreatedDate);
  }

  function getCartState(){
    try{
      return (CartUI && typeof CartUI.getState === "function") ? (CartUI.getState() || {}) : {};
    }catch(_){
      return {};
    }
  }

  function updateBadges(){
    const cart = getCartState();
    grid.querySelectorAll("[data-card-badge]").forEach((b) => {
      const uid = b.getAttribute("data-card-badge");
      const q = Math.floor(toNumber(cart?.[uid]) || 0);
      if(q > 0){
        b.classList.remove("d-none");
        b.innerHTML = `<i class="bi bi-cart-check"></i><span>${q}</span>`;
      }else{
        b.classList.add("d-none");
        b.innerHTML = "";
      }
    });
  }

  async function addToCart(uid, qty){
    uid = stripQuotes(uid);
    qty = Math.max(1, Math.floor(toNumber(qty) || 1));
    if(!uid) return;

    try{
      if(CartUI && typeof CartUI.add === "function"){
        await CartUI.add(uid, qty);
        if(typeof window.showToast === "function") window.showToast(`Ajouté au panier (x${qty})`, "success");
      }else{
        console.warn("[Nouveautés] CartUI.add indisponible");
        if(typeof window.showToast === "function") window.showToast("Panier indisponible.", "danger");
      }
    }catch(err){
      console.error(err);
      if(typeof window.showToast === "function") window.showToast("Erreur lors de l'ajout au panier.", "danger");
    }finally{
      updateBadges();
    }
  }

  function cardHtml(r){
    const uid = stripQuotes(r.UniqueId || "");
    const name = stripQuotes(r.DesComClear || r.FamilyName || r.xx_Vehicule || r.Id || "Article");
    const marque = stripQuotes(r.xx_Marque || "");
    const veh = stripQuotes(r.xx_Vehicule || "");
    const stock = toNumber(r.RealStock);
    const price = fmtMoney(r.SalePriceVatIncluded || r.SalePriceVatExcluded);
    const nameShort = truncate(name, 20);

    return `
      <div class="col-6 col-md-4 col-xl-2">
        <div class="new-card h-100">

          <span class="new-cart-pill d-none" data-card-badge="${esc(uid)}"></span>

          <div class="new-thumb">
            <img class="new-img"
                 src="${esc(imgUrl(uid))}"
                 alt="${esc(name)}"
                 loading="lazy"
              onerror="this.onerror=null;this.src='/img/default.png';"

>
          </div>

          <div class="new-body">
            <h3 class="new-name" title="${esc(name)}">${esc(nameShort)}</h3>
            <div class="new-meta">${esc(marque)}${marque && veh ? " · " : ""}${esc(veh)}</div>

            <div class="d-flex justify-content-between align-items-center">
              <div class="new-price text-primary">${esc(price)}</div>
              <span class="new-chip"><i class="bi bi-check2-circle"></i></span>
            </div>
          </div>

          
          </div>
        </div>
      </div>
    `;
  }
function truncate(s, max = 20){
  s = String(s ?? "").trim();
  return s.length > max ? s.slice(0, max) + "…" : s;
}
  async function load(){
    try{
      const res = await fetch(CSV_URL, { cache: "no-store", credentials: "same-origin", headers: { "Accept": "text/csv,*/*" } });
      const text = await res.text();
      if(!res.ok) throw new Error("HTTP " + res.status);

      if(!window.Papa){
        throw new Error("PapaParse manquant (window.Papa). Ajoute le CDN comme dans le catalogue.");
      }

      window.Papa.parse(text, {
        header: true,
        delimiter: ";",
        skipEmptyLines: true,
        transformHeader: (h) => stripQuotes(h),
        transform: (v) => stripQuotes(v),
        complete: (results) => {
          const rows = (results.data || [])
            .map(raw => {
              const out = {};
              for (const k in raw) out[stripQuotes(k)] = stripQuotes(raw[k]);
              return out;
            })
            .filter(r => Object.values(r).some(v => String(v || "").trim().length));

          const cutoff = new Date();
          cutoff.setDate(cutoff.getDate() - DAYS);

          // ✅ nouveautés + uniquement stock > 0
          const filtered = rows
            .map(r => ({ r, d: rowDate(r) }))
            .filter(x => x.d && x.d >= cutoff)
            .filter(x => (toNumber(x.r.RealStock) > 0))   // ✅ STOCK ONLY
            .sort((a,b) => b.d - a.d)
            .slice(0, LIMIT);

          if(filtered.length === 0){
            grid.innerHTML = "";
            empty.classList.remove("d-none");
            return;
          }

          empty.classList.add("d-none");
          grid.innerHTML = filtered.map(x => cardHtml(x.r)).join("");

          // Bind qty + add like catalogue
          grid.addEventListener("click", (e) => {
            const btn = e.target.closest("[data-action]");
            if(!btn) return;
            const action = btn.getAttribute("data-action");
            const uid = btn.getAttribute("data-uid");
            if(!uid) return;

            const form = btn.closest("form");
            const input = form?.querySelector(`input[name="qty"][data-uid="${uid}"]`);
            if(!input) return;

            let q = Math.max(1, Math.floor(toNumber(input.value) || 1));
            if(action === "qty-dec"){ q = Math.max(1, q - 1); input.value = String(q); }
            if(action === "qty-inc"){ q = q + 1; input.value = String(q); }
          }, { once: true });

          grid.addEventListener("submit", async (e) => {
            const form = e.target.closest("[data-cart-form]");
            if(!form) return;
            e.preventDefault();

            const fd = new FormData(form);
            const uid = String(fd.get("id") || "").trim();
            const qty = Math.max(1, Math.floor(toNumber(fd.get("qty")) || 1));
            await addToCart(uid, qty);
          });

          // Sync badge
          if(CartUI && typeof CartUI.sync === "function"){
            CartUI.sync().catch(() => {});
          }
          updateBadges();
        }
      });

    }catch(err){
      console.error(err);
      grid.innerHTML = "";
      empty.classList.remove("d-none");
      empty.innerHTML = `
        <div class="fw-bold">Impossible de charger les nouveautés</div>
        <div class="text-muted small">${esc(err.message || err)}</div>
      `;
    }
  }

  document.addEventListener("DOMContentLoaded", load);
})();
</script>
