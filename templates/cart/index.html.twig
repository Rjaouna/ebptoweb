{% extends 'base.html.twig' %}

{% block title %}Panier
{% endblock %}

{% block body %}
	<div class="container py-4">

		<div class="d-flex align-items-center justify-content-between mb-3">
			<div>
				<h1 class="h4 mb-1">Votre panier</h1>
				<div class="text-muted small">Modifiez les quantités puis validez.</div>
			</div>
			<span class="badge bg-primary" id="cartQtyBadge">{{ cartQty }}</span>
		</div>

		<div id="cartPageEmpty" class="alert alert-light border {% if cartQty > 0 %}d-none{% endif %}">
			Votre panier est vide.
		</div>

		<div id="cartPageList" class="d-grid gap-2"></div>

		<div class="row mt-3">
			<div class="col-lg-4 ms-auto">
				<div class="border rounded-4 p-3 bg-white">
					<div class="d-flex justify-content-between">
						<div class="fw-semibold">Total</div>
						<div class="fw-bold" id="cartPageTotal">—</div>
					</div>
					<div class="d-grid gap-2 mt-3">
						<button class="btn btn-outline-danger" id="btnCartPageClear" type="button">
							<i class="bi bi-trash"></i>
							Vider le panier
						</button>
						<a class="btn btn-primary" href="{{ path('catalogue_index') }}">
							<i class="bi bi-grid-3x3-gap"></i>
							Retour catalogue
						</a>
					</div>
				</div>
			</div>
		</div>

	</div>

	 <script>
	  // données du serveur (uid => qty)
	  window.__CART_MAP = {{ cartMap|json_encode|raw }};
	</script>
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
	<style>
		.cartp-item {
			display: flex;
			gap: 1rem;
			align-items: center;
			border: 1px solid rgba(0, 0, 0, .08);
			border-radius: 18px;
			padding: 0.75rem;
			background: #fff;
		}
		.cartp-thumb {
			width: 84px;
			height: 84px;
			border-radius: 18px;
			border: 1px solid rgba(0, 0, 0, .08);
			overflow: hidden;
			background: #f8f9fa;
			display: grid;
			place-items: center;
			flex: 0 0 auto;
		}
		.cartp-thumb img {
			width: 100%;
			height: 100%;
			object-fit: contain;
			background: #fff;
			display: block;
		}
		.cartp-meta {
			min-width: 0;
			flex: 1;
		}
		.cartp-title {
			font-weight: 800;
			line-height: 1.1;
		}
		.cartp-sub {
			font-size: 0.85rem;
			color: #6c757d;
		}
		.cartp-right {
			display: flex;
			flex-direction: column;
			align-items: end;
			gap: 0.5rem;
		}
		.cartp-qty {
			display: flex;
			align-items: center;
			gap: 0.35rem;
		}
		.cartp-qty input {
			width: 70px;
			text-align: center;
			border-radius: 14px;
		}
		.cartp-qty .btn {
			border-radius: 14px;
		}
	</style>
{% endblock %}

{% block javascripts %} <script src="https://cdn.jsdelivr.net/npm/papaparse@5.4.1/papaparse.min.js"></script>
	 <script>
	  const CSV_URL = "{{ path('catalogue_csv') }}";
	  const E = window.CART_ENDPOINTS || {};
	  const IMAGES_BASE = (window.CATALOG_CONFIG && window.CATALOG_CONFIG.imagesBase) ? window.CATALOG_CONFIG.imagesBase : "http://catalogue.3skpartsauto.com/export_images";
	  const LOCALE = (window.CATALOG_CONFIG && window.CATALOG_CONFIG.locale) ? window.CATALOG_CONFIG.locale : "fr-FR";
	  const CURRENCY = (window.CATALOG_CONFIG && window.CATALOG_CONFIG.currency) ? window.CATALOG_CONFIG.currency : "MAD";
	
	  let cartMap = window.__CART_MAP || {};
	  let productsByUid = new Map();
	
	  const listEl = document.getElementById("cartPageList");
	  const emptyEl = document.getElementById("cartPageEmpty");
	  const totalEl = document.getElementById("cartPageTotal");
	  const qtyBadge = document.getElementById("cartQtyBadge");
	  const btnClear = document.getElementById("btnCartPageClear");
	
	  function toNumber(v){
	    const n = Number(String(v ?? "").replace(",", ".").replace(/[^0-9.\-]/g,""));
	    return Number.isFinite(n) ? n : NaN;
	  }
	  function fmtMoney(n){
	    if(!Number.isFinite(n)) return "—";
	    try{ return new Intl.NumberFormat(LOCALE,{style:"currency",currency:CURRENCY,maximumFractionDigits:2}).format(n); }
	    catch(e){ return n.toFixed(2)+" "+CURRENCY; }
	  }
	  function esc(s){
	    return String(s ?? "").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;");
	  }
	  function imgUrl(uid){ return IMAGES_BASE + "/" + encodeURIComponent(uid) + ".png"; }
	
	  function totalQty(){
	    let n=0;
	    for(const uid in cartMap){
	      const q = Math.floor(toNumber(cartMap[uid])||0);
	      if(q>0) n+=q;
	    }
	    return n;
	  }
	
	  function getPrice(row){
	    const key = (window.CATALOG_CONFIG && window.CATALOG_CONFIG.priceMode==="exc") ? "SalePriceVatExcluded" : "SalePriceVatIncluded";
	    const n = toNumber(row?.[key]);
	    return Number.isFinite(n) ? n : NaN;
	  }
	
	  async function cartSet(uid, qty){
	    const res = await fetch(E.set, {
	      method:"POST",
	      credentials:"same-origin",
	      headers:{ "Content-Type":"application/x-www-form-urlencoded; charset=UTF-8", "X-Requested-With":"XMLHttpRequest" },
	      body: new URLSearchParams({ id: uid, qty: String(qty) })
	    });
	    const data = await res.json().catch(()=>null);
	    if(!res.ok || !data?.ok) return false;
	    cartMap = data.cart || {};
	    if(window.CartUI) window.CartUI.sync().catch(()=>{});
	    render();
	    return true;
	  }
	
	  async function cartClear(){
	    const res = await fetch(E.clear, {
	      method:"POST",
	      credentials:"same-origin",
	      headers:{ "X-Requested-With":"XMLHttpRequest", "Accept":"application/json" }
	    });
	    const data = await res.json().catch(()=>null);
	    if(!res.ok || !data?.ok) return false;
	    cartMap = {};
	    if(window.CartUI) window.CartUI.sync().catch(()=>{});
	    render();
	    return true;
	  }
	
	  function render(){
	    const keys = Object.keys(cartMap).filter(uid => (toNumber(cartMap[uid])||0) > 0);
	    const has = keys.length > 0;
	
	    emptyEl.classList.toggle("d-none", has);
	    listEl.innerHTML = "";
	    totalEl.textContent = "—";
	    qtyBadge.textContent = String(totalQty());
	
	    if(!has) return;
	
	    let totalVal = 0;
	
	    for(const uid of keys.sort((a,b)=>a.localeCompare(b,"fr"))){
	      const qty = Math.floor(toNumber(cartMap[uid])||0);
	      const row = productsByUid.get(uid);
	
	      const title = row?.DesComClear || row?.Designation || uid;
	      const brand = row?.xx_Marque || "";
	      const veh = row?.xx_Vehicule || row?.xx_VEHICULE || "";
	      const family = row?.FamilyName || "";
	
	      const price = row ? getPrice(row) : NaN;
	      const sub = (Number.isFinite(price) ? price * qty : NaN);
	      if(Number.isFinite(sub)) totalVal += sub;
	
	      const div = document.createElement("div");
	      div.className = "cartp-item";
	      div.innerHTML = `
	        <div class="cartp-thumb">
	          <img src="${imgUrl(uid)}" alt=""
	            onerror="this.onerror=null;this.src='data:image/svg+xml;utf8,${encodeURIComponent(`<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><rect width='100%' height='100%' fill='%23f1f3f5'/><text x='50%' y='52%' text-anchor='middle' fill='%236c757d' font-family='Arial' font-size='14'>No image</text></svg>`)}';">
	        </div>
	
	        <div class="cartp-meta">
	          <div class="cartp-title text-truncate">${esc(title)}</div>
	          <div class="cartp-sub">
	            ${brand ? esc(brand) + " • " : ""}${family ? esc(family) + " • " : ""}${veh ? esc(veh) + " • " : ""}UID: ${esc(uid)}
	          </div>
	          <div class="cartp-sub mt-1">
	            ${Number.isFinite(price) ? ("PU: <b>"+fmtMoney(price)+"</b>") : ""}
	            ${Number.isFinite(sub) ? (" • Sous-total: <b>"+fmtMoney(sub)+"</b>") : ""}
	          </div>
	        </div>
	
	        <div class="cartp-right">
	          <div class="cartp-qty">
	            <button class="btn btn-outline-secondary btn-sm" data-dec="${uid}" type="button">-</button>
	            <input class="form-control form-control-sm" data-qty="${uid}" type="number" min="1" value="${qty}">
	            <button class="btn btn-outline-secondary btn-sm" data-inc="${uid}" type="button">+</button>
	          </div>
	          <button class="btn btn-outline-danger btn-sm" data-rm="${uid}" type="button">
	            <i class="bi bi-x-lg"></i> Supprimer
	          </button>
	        </div>
	      `;
	      listEl.appendChild(div);
	    }
	
	    if(Number.isFinite(totalVal)) totalEl.textContent = fmtMoney(totalVal);
	  }
	
	  listEl.addEventListener("click", async (e)=>{
	    const inc = e.target.closest("[data-inc]")?.getAttribute("data-inc");
	    const dec = e.target.closest("[data-dec]")?.getAttribute("data-dec");
	    const rm  = e.target.closest("[data-rm]")?.getAttribute("data-rm");
	
	    if(inc){
	      const q = Math.floor(toNumber(cartMap[inc])||0) + 1;
	      await cartSet(inc, q);
	    }
	    if(dec){
	      const q = Math.max(1, Math.floor(toNumber(cartMap[dec])||1) - 1);
	      await cartSet(dec, q);
	    }
	    if(rm){
	      await cartSet(rm, 0);
	    }
	  });
	
	  listEl.addEventListener("change", async (e)=>{
	    const inp = e.target.closest("[data-qty]");
	    if(!inp) return;
	    const uid = inp.getAttribute("data-qty");
	    const q = Math.max(1, Math.floor(toNumber(inp.value)||1));
	    await cartSet(uid, q);
	  });
	
	  btnClear.addEventListener("click", async ()=>{ await cartClear(); });
	
	  async function loadCsv(){
	    const res = await fetch(CSV_URL, { cache:"no-store" });
	    if(!res.ok) return;
	
	    const text = await res.text();
	
	    Papa.parse(text,{
	      header:true,
	      delimiter:";",
	      skipEmptyLines:true,
	      complete:(results)=>{
	        let rows = (results.data || []);
	        // fallback delimiter
	        const fields = results?.meta?.fields || [];
	        if(fields.length < 5){
	          Papa.parse(text,{ header:true, delimiter:",", skipEmptyLines:true,
	            complete:(r2)=>{ rows = (r2.data||[]); hydrateProducts(rows); }
	          });
	          return;
	        }
	        hydrateProducts(rows);
	      }
	    });
	  }
	
	  function hydrateProducts(rows){
	    productsByUid = new Map();
	    for(const r of rows){
	      const uid = r?.UniqueId || r?.Id || r?.ID || r?.id;
	      if(uid) productsByUid.set(String(uid).trim(), r);
	    }
	
	    // expose to menu offcanvas too
	    window.__productByUid = productsByUid;
	    if(window.CartUI) window.CartUI.sync().catch(()=>{});
	    render();
	  }
	
	  // init
	  loadCsv().catch(()=>{ render(); });
	</script>
{% endblock %}

