{# templates/catalogue/_filters_top.html.twig #}

<div class="filters-top card filter-card p-3" id="filtersCard">
  <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
    <div class="fw-semibold d-flex align-items-center gap-2">
      <span class="icon-pill"><i class="bi bi-sliders2"></i></span>
      <span>Filtres</span>
    </div>

    <button id="btnReset2" class="btn btn-sm btn-outline-secondary" type="button">
      <i class="bi bi-arrow-counterclockwise me-1"></i>Réinitialiser
    </button>
  </div>

  <div class="filters-grid">
    {# PRIX #}
    <div class="fblock">
      <div class="fblock-title">Prix</div>
      <div class="d-flex gap-3 flex-wrap">
        <div class="form-check">
          <input class="form-check-input" type="radio" name="priceMode" id="pmInc" value="inc" checked>
          <label class="form-check-label" for="pmInc">TTC</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="priceMode" id="pmExc" value="exc">
          <label class="form-check-label" for="pmExc">HT</label>
        </div>
      </div>
    </div>

    {# STOCK #}
    <div class="fblock">
      <div class="fblock-title">Stock</div>
      <div class="d-flex gap-3 flex-wrap">
        <div class="form-check">
          <input class="form-check-input" type="radio" name="stockMode" id="smAll" value="all" checked>
          <label class="form-check-label" for="smAll">Tous</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="stockMode" id="smIn" value="in">
          <label class="form-check-label" for="smIn">En stock</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="stockMode" id="smOut" value="out">
          <label class="form-check-label" for="smOut">Rupture</label>
        </div>
      </div>
    </div>

    {# MARQUE #}
    <div class="fblock">
      <div class="fblock-title">Marque</div>
      <select id="fBrand" class="form-select form-select-sm">
        <option value="">Toutes</option>
      </select>
    </div>

    {# FAMILLE #}
    <div class="fblock">
      <div class="fblock-title">Famille</div>
      <select id="fFamily" class="form-select form-select-sm">
        <option value="">Toutes</option>
      </select>
    </div>

    {# VEHICULE #}
    <div class="fblock">
      <div class="fblock-title">Véhicule</div>
      <select id="fVehicle" class="form-select form-select-sm">
        <option value="">Tous</option>
      </select>
    </div>

    {# ANNEE #}
    <div class="fblock">
      <div class="fblock-title">Année</div>
      <div class="row g-2">
        <div class="col-6"><input id="fYearMin" class="form-control form-control-sm" type="number" placeholder="Min"></div>
        <div class="col-6"><input id="fYearMax" class="form-control form-control-sm" type="number" placeholder="Max"></div>
      </div>
    </div>

    {# PRIX MIN/MAX #}
    <div class="fblock">
      <div class="fblock-title">Prix min/max</div>
      <div class="row g-2">
        <div class="col-6"><input id="fPriceMin" class="form-control form-control-sm" type="number" placeholder="Min"></div>
        <div class="col-6"><input id="fPriceMax" class="form-control form-control-sm" type="number" placeholder="Max"></div>
      </div>
    </div>

    {# TRI #}
    <div class="fblock">
      <div class="fblock-title">Tri</div>
      <select id="fSort" class="form-select form-select-sm">
        <option value="relevance">Pertinence</option>
        <option value="priceAsc">Prix (croissant)</option>
        <option value="priceDesc">Prix (décroissant)</option>
        <option value="stockDesc">Stock (décroissant)</option>
        <option value="az">Nom (A → Z)</option>
        <option value="newest">Plus récents</option>
      </select>
    </div>
  </div>

  <div class="small text-muted mt-2">
    Astuce : recherche marque, véhicule, famille, UID…
  </div>
</div>
