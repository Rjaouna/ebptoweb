{% extends 'base.html.twig' %}

{% block title %}Nouveautés{% endblock %}

{% block body %}
  {% include 'catalogue/_catalogue.html.twig' with {
    pageMode: 'all',
    pageTitle: 'Nouveautés',
    newDays: newDays|default(5)
  } %}
{% endblock %}

{% block javascripts %}
  {{ parent() }}

  {# ✅ csvUrl DOIT venir du controller (ex: /catalogue/csv/new?days=5&field=exportstartedat) #}
  <script>
    window.CATALOG_CONFIG = {
      csvUrl: "{{ csvUrl|e('js') }}",
      imagesBase: "{{ imagesBase|e('js') }}",
      pageMode: "all",            // ✅ IMPORTANT : pas "new"
      newDays: {{ newDays|default(5) }},
      locale: "fr-FR",
      currency: "MAD"
    };
    console.log("CATALOG_CONFIG (new)", window.CATALOG_CONFIG);
  </script>

  {# ⚠️ si PapaParse est déjà dans base.html.twig, ne le remets pas ici #}
  <script src="{{ asset('js/catalogue.js') }}"></script>
{% endblock %}
