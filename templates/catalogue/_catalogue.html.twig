{# templates/catalogue/_catalogue.html.twig #}
{# variables: pageMode, pageTitle, newDays #}

<div class="container-fluid">

  <nav class="navbar glass border-bottom my-3" style="position:sticky;top:0;z-index:1030;">
    <div class="container-fluid py-2 gap-3 align-items-center">
      <div class="d-flex flex-column lh-sm">
        <div class="fw-bold" style="font-size:1.05rem;">{{ pageTitle }}</div>
        <div class="text-muted small">Catalogue & export</div>
      </div>

      <div class="flex-grow-1">
        <div class="input-group input-group-lg shadow-sm search-group">
          <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
          <input id="qTop" type="search" class="form-control" placeholder="Rechercher une pièce, marque, véhicule, référence…">
          <button id="btnClearQ" class="btn btn-outline-secondary" type="button" title="Effacer">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
      </div>

      <div class="d-flex align-items-center gap-2 ms-auto flex-shrink-0">
        <button class="btn btn-outline-primary d-lg-none" type="button"
                data-bs-toggle="offcanvas" data-bs-target="#filtersCanvas" aria-label="Filtres">
          <i class="bi bi-sliders2"></i>
        </button>
      </div>
    </div>
  </nav>

  <div class="row g-4">
    <aside class="col-lg-3 d-none d-lg-block">
      <div id="filtersDesktopMount">
        {% include 'catalogue/_filters.html.twig' %}
      </div>
    </aside>

    <section class="col-lg-9">
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2 bg-white p-2 rounded">
        <div>
          <div class="fw-semibold">
            Résultats : <span id="count">0</span>
            <span class="text-muted fw-normal">/ <span id="total">0</span></span>
          </div>
          <div id="hint" class="small text-muted"></div>
        </div>

        <div class="d-flex gap-2">
          <button id="btnReset" class="btn btn-sm btn-outline-secondary" type="button">
            <i class="bi bi-arrow-counterclockwise"></i> Réinitialiser
          </button>
        </div>
      </div>

      <div id="chips" class="mb-3"></div>
      <div id="grid" class="row g-3"></div>

      <div class="text-center my-3">
        <button id="btnMore" class="btn btn-outline-primary d-none" type="button">Afficher plus</button>
      </div>

      <div id="empty" class="text-center py-5 d-none">
        <div class="display-6">Aucun produit</div>
        <div class="text-muted">Essayez d’assouplir vos filtres.</div>
      </div>
    </section>
  </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="filtersCanvas">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title"><i class="bi bi-sliders2"></i> Filtres</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body">
    <div id="filtersClone"></div>
  </div>
</div>
<script>
  window.STOCK_ENDPOINTS = { reserved: "{{ path('stock_reserved') }}" };
</script>
