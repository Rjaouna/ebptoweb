{% extends 'base.html.twig' %}
{% set route = app.request.attributes.get('_route') %}

{% block title %}Admin • Boutique{% endblock %}

{% block body %}
<div class="container py-4">

  <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div class="min-w-0">
      <div class="d-flex align-items-center gap-2">
        <div class="store-icon"><i class="bi bi-shop"></i></div>
        <div class="min-w-0">
          <h1 class="h4 mb-1 fw-black text-truncate">Paramètres boutique</h1>
          <div class="text-muted small text-truncate">1 seule fiche • sauvegarde AJAX • logo optionnel</div>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <button class="btn btn-outline-secondary rounded-pill" id="btnStoreReload" type="button">
        <i class="bi bi-arrow-repeat me-2"></i>Recharger
      </button>
      <button class="btn btn-primary rounded-pill" id="btnStoreSave" type="button">
        <i class="bi bi-check2-circle me-2"></i>Enregistrer
      </button>
    </div>
  </div>

  <div class="alert alert-danger rounded-4 d-none" id="storeError"></div>
  <div class="alert alert-success rounded-4 d-none" id="storeSuccess"></div>

  <div class="row g-3">
    <div class="col-lg-8">

      <div class="card border-0 shadow-sm rounded-4 overflow-hidden store-card">
        <div class="card-body p-3 p-lg-4">

          <div class="section-title mb-2">
            <i class="bi bi-person-badge me-2 text-primary"></i>Identité & contact
          </div>

          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label">Nom boutique</label>
              <input class="form-control" id="st_name" placeholder="Hopic">
            </div>
            <div class="col-md-6">
              <label class="form-label">Raison sociale (optionnel)</label>
              <input class="form-control" id="st_legalName" placeholder="HOPIC SARL ...">
            </div>

            <div class="col-md-6">
              <label class="form-label">Email notifications</label>
              <input class="form-control" id="st_email" type="email" placeholder="contact@...">
            </div>
            <div class="col-md-6">
              <label class="form-label">Téléphone</label>
              <input class="form-control" id="st_phone" placeholder="+212 ...">
            </div>

            <div class="col-12">
              <label class="form-label">Site web</label>
              <input class="form-control" id="st_website" placeholder="https://...">
            </div>
          </div>

          <hr class="my-4">

          <div class="section-title mb-2">
            <i class="bi bi-geo-alt me-2 text-primary"></i>Adresse postale
          </div>

          <div class="row g-2">
            <div class="col-12">
              <label class="form-label">Adresse ligne 1</label>
              <input class="form-control" id="st_addressLine1" placeholder="Rue, numéro...">
            </div>
            <div class="col-12">
              <label class="form-label">Adresse ligne 2 (optionnel)</label>
              <input class="form-control" id="st_addressLine2" placeholder="Appartement, étage...">
            </div>
            <div class="col-md-4">
              <label class="form-label">Code postal</label>
              <input class="form-control" id="st_postalCode" placeholder="20000">
            </div>
            <div class="col-md-4">
              <label class="form-label">Ville</label>
              <input class="form-control" id="st_city" placeholder="Casablanca">
            </div>
            <div class="col-md-4">
              <label class="form-label">Région</label>
              <input class="form-control" id="st_region" placeholder="...">
            </div>
            <div class="col-md-6">
              <label class="form-label">Pays</label>
              <input class="form-control" id="st_country" placeholder="Maroc">
            </div>
          </div>

          <hr class="my-4">

          <div class="section-title mb-2">
            <i class="bi bi-shield-check me-2 text-primary"></i>Informations légales (optionnel)
          </div>

          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label">ICE</label>
              <input class="form-control" id="st_ice" placeholder="...">
            </div>
            <div class="col-md-6">
              <label class="form-label">TVA / VAT</label>
              <input class="form-control" id="st_vatNumber" placeholder="...">
            </div>
            <div class="col-md-6">
              <label class="form-label">RC</label>
              <input class="form-control" id="st_rc" placeholder="...">
            </div>
            <div class="col-md-6">
              <label class="form-label">IF</label>
              <input class="form-control" id="st_ifNumber" placeholder="...">
            </div>
          </div>

          <hr class="my-4">

          <div class="section-title mb-2">
            <i class="bi bi-sliders me-2 text-primary"></i>Paramètres
          </div>

          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label">Devise</label>
              <input class="form-control" id="st_currency" placeholder="MAD">
              <div class="small text-muted mt-1">Ex: MAD, EUR, USD…</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">Locale</label>
              <input class="form-control" id="st_locale" placeholder="fr_FR">
              <div class="small text-muted mt-1">Ex: fr_FR, fr-FR…</div>
            </div>
          </div>

        </div>
      </div>

    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 90px;">
        <div class="card-body p-3 p-lg-4">

          <div class="section-title mb-2">
            <i class="bi bi-image me-2 text-primary"></i>Branding
          </div>

          <div class="brand-preview p-3 rounded-4 border">
            <div class="d-flex align-items-center gap-3">
              <div class="logo-box">
                <img id="logoImg" src="{{ asset('img/default.png') }}" alt="Logo" style="width:100%;height:100%;object-fit:contain;">
              </div>
              <div class="min-w-0">
                <div class="fw-black" id="previewName">—</div>
                <div class="text-muted small text-truncate" id="previewEmail">—</div>
                <div class="small text-muted mt-1" id="previewAddress">—</div>
              </div>
            </div>
          </div>

          <div class="mt-3">
            <label class="form-label">Logo</label>
            <input class="form-control" type="file" id="st_logo" accept="image/png,image/jpeg,image/webp,image/svg+xml">
            <div class="small text-muted mt-2">
              PNG/JPG/WEBP/SVG. Le fichier sera stocké dans <code>public/img/store</code>.
            </div>
            <button class="btn btn-outline-secondary rounded-pill mt-3 w-100" type="button" id="btnUploadLogo">
              <i class="bi bi-cloud-upload me-2"></i>Uploader le logo
            </button>
          </div>

          <hr class="my-3">

          <div class="d-flex justify-content-between align-items-center">
            <div class="text-muted small">Store ID</div>
            <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">
              {{ storeId }}
            </span>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.ADMIN_STORE = {
    getUrl: "{{ path('admin_store_ajax_get') }}",
    saveUrl: "{{ path('admin_store_ajax_save') }}",
    logoUrl: "{{ path('admin_store_ajax_logo') }}",
    csrfSave: "{{ csrfSave }}",
    csrfLogo: "{{ csrfLogo }}",
    defaultLogo: "{{ asset('img/default.png') }}",
    assetBase: "{{ app.request.schemeAndHttpHost ~ app.request.basePath }}/"
  };
</script>

<style>
  .fw-black{ font-weight: 900; }
  .store-icon{
    width:44px;height:44px;border-radius:14px;display:grid;place-items:center;
    background: rgba(var(--bs-primary-rgb), .12);
    border: 1px solid rgba(var(--bs-primary-rgb), .18);
    color: var(--bs-primary);
    flex:0 0 auto;
  }
  .store-card{
    background: linear-gradient(180deg, rgba(var(--bs-primary-rgb), .06), rgba(255,255,255,0));
  }
  .section-title{
    font-weight: 900;
    color: rgba(17,24,39,.80);
    font-size: .9rem;
  }
  .brand-preview{
    background: rgba(255,255,255,.92);
  }
  .logo-box{
    width:72px;height:72px;border-radius:18px;
    display:grid;place-items:center;
    border: 1px solid rgba(0,0,0,.08);
    background:#fff;
    overflow:hidden;
    flex: 0 0 auto;
  }
</style>
{% endblock %}

{% block javascripts %}
<script>
(function(){
  const CFG = window.ADMIN_STORE || {};
  const $ = (id) => document.getElementById(id);

  const errorEl = $("storeError");
  const successEl = $("storeSuccess");

  const fields = {
    name: $("st_name"),
    legalName: $("st_legalName"),
    email: $("st_email"),
    phone: $("st_phone"),
    website: $("st_website"),

    addressLine1: $("st_addressLine1"),
    addressLine2: $("st_addressLine2"),
    postalCode: $("st_postalCode"),
    city: $("st_city"),
    region: $("st_region"),
    country: $("st_country"),

    ice: $("st_ice"),
    vatNumber: $("st_vatNumber"),
    rc: $("st_rc"),
    ifNumber: $("st_ifNumber"),

    currency: $("st_currency"),
    locale: $("st_locale"),
  };

  const logoInput = $("st_logo");
  const logoImg = $("logoImg");

  const previewName = $("previewName");
  const previewEmail = $("previewEmail");
  const previewAddress = $("previewAddress");

  const btnSave = $("btnStoreSave");
  const btnReload = $("btnStoreReload");
  const btnUploadLogo = $("btnUploadLogo");

  function showError(msg){
    if(!errorEl) return;
    errorEl.classList.toggle("d-none", !msg);
    errorEl.textContent = msg || "";
  }
  function showSuccess(msg){
    if(!successEl) return;
    successEl.classList.toggle("d-none", !msg);
    successEl.textContent = msg || "";
    if(msg){
      setTimeout(()=>showSuccess(""), 1800);
    }
  }

  function assetUrl(path){
    if(!path) return CFG.defaultLogo;
    const p = String(path).replace(/^\/+/,'');
    return CFG.assetBase + p;
  }

  function refreshPreview(){
    const name = fields.name?.value?.trim() || "—";
    const email = fields.email?.value?.trim() || "—";
    const addr1 = fields.addressLine1?.value?.trim() || "";
    const pc = fields.postalCode?.value?.trim() || "";
    const city = fields.city?.value?.trim() || "";
    const country = fields.country?.value?.trim() || "";
    const addr = [addr1, [pc, city].filter(Boolean).join(" "), country].filter(Boolean).join(" • ");

    previewName && (previewName.textContent = name);
    previewEmail && (previewEmail.textContent = email);
    previewAddress && (previewAddress.textContent = addr || "—");
  }

  function fill(store){
    if(!store) return;

    fields.name.value = store.name ?? "";
    fields.legalName.value = store.legalName ?? "";
    fields.email.value = store.email ?? "";
    fields.phone.value = store.phone ?? "";
    fields.website.value = store.website ?? "";

    fields.addressLine1.value = store.addressLine1 ?? "";
    fields.addressLine2.value = store.addressLine2 ?? "";
    fields.postalCode.value = store.postalCode ?? "";
    fields.city.value = store.city ?? "";
    fields.region.value = store.region ?? "";
    fields.country.value = store.country ?? "";

    fields.ice.value = store.ice ?? "";
    fields.vatNumber.value = store.vatNumber ?? "";
    fields.rc.value = store.rc ?? "";
    fields.ifNumber.value = store.ifNumber ?? "";

    fields.currency.value = store.currency ?? "MAD";
    fields.locale.value = store.locale ?? "fr_FR";

    logoImg && (logoImg.src = store.logoPath ? assetUrl(store.logoPath) : CFG.defaultLogo);

    refreshPreview();
  }

  async function load(){
    showError("");
    try{
      const res = await fetch(CFG.getUrl, {
        credentials: "same-origin",
        headers: { "Accept":"application/json", "X-Requested-With":"XMLHttpRequest" }
      });
      const data = await res.json().catch(()=>null);
      if(!res.ok || !data?.ok){
        showError(data?.message || ("Erreur chargement (HTTP " + res.status + ")"));
        return;
      }
      fill(data.store);
    }catch(e){
      showError("Erreur réseau.");
    }
  }

  async function save(){
    showError("");
    const body = new URLSearchParams();
    body.set("_token", CFG.csrfSave || "");

    for(const [k, el] of Object.entries(fields)){
      body.set(k, el?.value ?? "");
    }

    btnSave && (btnSave.disabled = true);

    try{
      const res = await fetch(CFG.saveUrl, {
        method: "POST",
        credentials: "same-origin",
        headers: {
          "Content-Type":"application/x-www-form-urlencoded; charset=UTF-8",
          "X-Requested-With":"XMLHttpRequest",
          "Accept":"application/json",
          "X-CSRF-TOKEN": CFG.csrfSave || ""
        },
        body
      });
      const data = await res.json().catch(()=>null);
      if(!res.ok || !data?.ok){
        showError(data?.message || ("Erreur sauvegarde (HTTP " + res.status + ")"));
        return;
      }
      fill(data.store);
      showSuccess("✅ Sauvegardé.");
    }catch(e){
      showError("Erreur réseau.");
    }finally{
      btnSave && (btnSave.disabled = false);
    }
  }

  async function uploadLogo(){
    showError("");
    const file = logoInput?.files?.[0];
    if(!file){
      showError("Choisis un fichier logo.");
      return;
    }

    btnUploadLogo && (btnUploadLogo.disabled = true);

    const fd = new FormData();
    fd.append("_token", CFG.csrfLogo || "");
    fd.append("logo", file);

    try{
      const res = await fetch(CFG.logoUrl, {
        method: "POST",
        credentials: "same-origin",
        headers: {
          "X-Requested-With":"XMLHttpRequest",
          "Accept":"application/json",
          "X-CSRF-TOKEN": CFG.csrfLogo || ""
        },
        body: fd
      });
      const data = await res.json().catch(()=>null);
      if(!res.ok || !data?.ok){
        showError(data?.message || ("Erreur upload (HTTP " + res.status + ")"));
        return;
      }
      fill(data.store);
      showSuccess("✅ Logo mis à jour.");
    }catch(e){
      showError("Erreur réseau.");
    }finally{
      btnUploadLogo && (btnUploadLogo.disabled = false);
      if(logoInput) logoInput.value = "";
    }
  }

  // live preview
  Object.values(fields).forEach(el => el?.addEventListener("input", refreshPreview));

  btnSave?.addEventListener("click", save);
  btnReload?.addEventListener("click", load);
  btnUploadLogo?.addEventListener("click", uploadLogo);

  // init robuste
  function init(){ load(); }
  if(document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
  else init();
  document.addEventListener("turbo:load", init);
})();
</script>
{% endblock %}
