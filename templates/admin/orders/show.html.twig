{# templates/admin/orders/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Admin • Commande {{ order.reference ?: ('CMD-' ~ order.id) }}{% endblock %}

{% block body %}
<div class="container py-4">

  <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div class="min-w-0">
      <div class="d-flex align-items-center gap-2">
      
        <div class="min-w-0">
          <h1 class="h4 mb-1 fw-black text-truncate">
            Commande {{ order.reference ?: ('CMD-' ~ order.id) }}
          </h1>
          <div class="text-muted small text-truncate">
            Client: {{ order.user ? order.user.email : '—' }} •
            Créée: {{ order.createdAt ? order.createdAt|date('d/m/Y H:i') : '—' }}
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex align-items-center gap-2">
      <a href="{{ path('admin_orders_index') }}" class="btn btn-outline-secondary rounded-pill">
        <i class="bi bi-arrow-left me-2"></i>Retour
      </a>

      <button class="btn btn-primary rounded-pill" type="button" id="btnOpenStatus">
        <i class="bi bi-pencil-square me-2"></i>Changer le statut
      </button>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-12 col-lg-8">

      <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-3">
        <div class="card-body p-3 p-lg-4">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <div class="fw-black">Statut :</div>
              <span class="order-status">{{ statusLabel }}</span>
              <span class="text-muted small">({{ order.status }})</span>
            </div>

            <div class="text-end">
              <div class="fw-black">{{ order.totalTtc is not null ? (order.totalTtc ~ ' MAD') : '—' }}</div>
              <div class="text-muted small">Total TTC</div>
            </div>
          </div>

          {% if order.note %}
            <hr class="my-3">
            <div class="text-muted small">Note</div>
            <div class="fw-semibold">{{ order.note }}</div>
          {% endif %}
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-3 p-lg-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="fw-black"><i class="bi bi-list-check me-2 text-primary"></i>Lignes de commande</div>
            <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">
              {{ order.commandeLignes|length }} article(s)
            </span>
          </div>

          {% if order.commandeLignes|length == 0 %}
            <div class="alert alert-light border rounded-4 mb-0">
              <i class="bi bi-inbox me-2"></i>Aucune ligne.
            </div>
          {% else %}
            <div class="d-grid gap-2">
              {% for l in order.commandeLignes %}
                <div class="line-row">
                  <div class="min-w-0">
                    <div class="fw-semibold text-truncate">
                      {{ l.name ?? ('Article ' ~ loop.index) }}
                    </div>
                    <div class="text-muted small text-truncate">
                      UID: {{ l.uid ?? '—' }}
                    </div>
                  </div>

                  <div class="text-end">
                    <div class="fw-black">x{{ l.quantity ?? 1 }}</div>
                    <div class="text-muted small">
                      {{ l.lineTotalTtc is not null ? (l.lineTotalTtc ~ ' MAD') : '' }}
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>

    </div>

    <div class="col-12 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-3 p-lg-4">
          <div class="fw-black mb-2"><i class="bi bi-person-badge me-2 text-primary"></i>Client</div>

          <div class="small text-muted">Email</div>
          <div class="fw-semibold text-truncate">{{ order.user ? order.user.email : '—' }}</div>

          <hr class="my-3">

          <div class="fw-black mb-2"><i class="bi bi-info-circle me-2 text-primary"></i>Infos</div>
          <div class="d-grid gap-2 small">
            <div class="d-flex justify-content-between gap-2">
              <span class="text-muted">ID</span>
              <span class="fw-semibold">#{{ order.id }}</span>
            </div>
            <div class="d-flex justify-content-between gap-2">
              <span class="text-muted">Référence</span>
              <span class="fw-semibold">{{ order.reference ?: ('CMD-' ~ order.id) }}</span>
            </div>
            <div class="d-flex justify-content-between gap-2">
              <span class="text-muted">Créée</span>
              <span class="fw-semibold">{{ order.createdAt ? order.createdAt|date('d/m/Y H:i') : '—' }}</span>
            </div>
            <div class="d-flex justify-content-between gap-2">
              <span class="text-muted">MAJ</span>
              <span class="fw-semibold">{{ order.updatedAt ? order.updatedAt|date('d/m/Y H:i') : '—' }}</span>
            </div>
          </div>

          <hr class="my-3">

          <div class="fw-black mb-2"><i class="bi bi-arrow-repeat me-2 text-primary"></i>Transition</div>

          {% if allowedNext|length == 0 %}
            <div class="alert alert-light border rounded-4 mb-0">
              Aucun changement possible depuis ce statut.
            </div>
          {% else %}
            <div class="text-muted small mb-2">Prochain(s) statut(s) possible(s) :</div>
            <div class="d-flex flex-wrap gap-2">
              {% for st in allowedNext %}
                <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis border border-primary-subtle">
                  {{ st }}
                </span>
              {% endfor %}
            </div>
          {% endif %}

        </div>
      </div>
    </div>
  </div>

</div>

{# Modal status #}
<div class="modal fade" id="statusModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 overflow-hidden">
      <div class="p-3 p-lg-4" style="background: linear-gradient(180deg, rgba(227,32,27,.10), rgba(255,255,255,0));">
        <div class="d-flex align-items-start justify-content-between gap-3">
          <div class="min-w-0">
            <div class="fw-black mb-1">Changer le statut</div>
            <div class="text-muted small">Commande {{ order.reference ?: ('CMD-' ~ order.id) }}</div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="mt-3 d-grid gap-2" id="statusChoices"></div>

        <div class="text-muted small mt-3">
          ⚠️ Transitions verrouillées : pas de saut, pas de retour en arrière.
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.ADMIN_ORDER_SHOW = {
    id: {{ order.id }},
    allowedNext: {{ allowedNext|json_encode|raw }},
    statusUrl: "{{ path('admin_orders_ajax_status', {id: order.id}) }}",
    csrf: "{{ csrfStatus }}"
  };
</script>

<style>
  .fw-black{ font-weight:900; }
  .orders-icon{
    width:44px;height:44px;border-radius:14px;display:grid;place-items:center;
    background: rgba(var(--bs-primary-rgb), .12);
    border: 1px solid rgba(var(--bs-primary-rgb), .18);
    color: var(--bs-primary);
    flex:0 0 auto;
  }
  .order-status{
    font-size:.75rem;border-radius:999px;padding:.25rem .55rem;
    border:1px solid rgba(0,0,0,.08);
    background: rgba(108,117,125,.08);
    color:#495057; white-space:nowrap;
  }
  .line-row{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px;
    background: #fff;
    padding: 12px 14px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap: 12px;
  }
  .status-choice{
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,.06);
    background: #fff;
    padding: 12px 14px;
    display:flex; align-items:center; justify-content:space-between; gap:12px;
    transition: transform .12s ease, box-shadow .12s ease;
    cursor:pointer;
  }
  .status-choice:hover{ transform: translateY(-1px); box-shadow: 0 .35rem 1rem rgba(0,0,0,.06); }
  .status-choice .hint{ color:#6c757d; font-size:.85rem; }
</style>
{% endblock %}

{% block javascripts %}
<script>
(function(){
  const CFG = window.ADMIN_ORDER_SHOW || {};
  const modalEl = document.getElementById("statusModal");
  const choicesEl = document.getElementById("statusChoices");
  const btn = document.getElementById("btnOpenStatus");
  const modal = modalEl ? bootstrap.Modal.getOrCreateInstance(modalEl) : null;

  function esc(s){
    return String(s ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#039;");
  }

  function labelForStatus(st){
    const map = {
      reserved: "Reçue",
      preparing: "En préparation",
      ready: "Terminée",
      shipped: "Expédiée",
      delivered: "Livrée",
      cancelled: "Annulée",
    };
    return map[st] || st;
  }

  async function applyStatus(nextStatus){
    const body = new URLSearchParams();
    body.set("status", nextStatus);
    body.set("_token", CFG.csrf || "");

    const res = await fetch(CFG.statusUrl, {
      method: "POST",
      credentials: "same-origin",
      headers: {
        "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
        "X-Requested-With": "XMLHttpRequest",
        "Accept": "application/json",
        "X-CSRF-TOKEN": CFG.csrf || ""
      },
      body
    });

    const data = await res.json().catch(()=>null);
    if(!res.ok || !data?.ok){
      alert(data?.message || ("Erreur HTTP " + res.status));
      return false;
    }
    return true;
  }

  function open(){
    if(!choicesEl) return;
    const allowed = Array.isArray(CFG.allowedNext) ? CFG.allowedNext : [];

    choicesEl.innerHTML = "";

    if(!allowed.length){
      choicesEl.innerHTML = `
        <div class="alert alert-light border rounded-4 mb-0">
          Aucun changement possible depuis ce statut.
        </div>
      `;
      modal?.show();
      return;
    }

    for(const st of allowed){
      const div = document.createElement("div");
      div.className = "status-choice";
      div.innerHTML = `
        <div class="min-w-0">
          <div class="fw-black">${esc(labelForStatus(st))}</div>
          <div class="hint">Appliquer : <b>${esc(st)}</b></div>
        </div>
        <i class="bi bi-arrow-right"></i>
      `;

      div.addEventListener("click", async () => {
        div.style.pointerEvents = "none";
        div.style.opacity = ".7";

        const ok = await applyStatus(st);
        if(ok){
          modal?.hide();
          window.location.reload();
        }else{
          div.style.pointerEvents = "";
          div.style.opacity = "";
        }
      });

      choicesEl.appendChild(div);
    }

    modal?.show();
  }

  btn?.addEventListener("click", open);

})();
</script>
{% endblock %}
