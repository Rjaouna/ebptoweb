{# templates/admin/orders/index.html.twig #}
{% extends 'base.html.twig' %}
{% set route = app.request.attributes.get('_route') %}

{% block title %}Admin • Commandes{% endblock %}

{% block body %}
<div class="container py-4">

  <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div class="min-w-0">
      <div class="d-flex align-items-center gap-2">
    
        <div class="min-w-0">
          <h1 class="h4 mb-1 fw-black text-truncate">Commandes (Admin)</h1>
          <div class="text-muted small text-truncate">Liste globale • Recherche • Mise à jour du statut</div>
        </div>
      </div>
    </div>

    <button class="btn btn-primary rounded-pill" id="btnOrdersRefresh" type="button">
      <i class="bi bi-arrow-repeat me-2"></i>Actualiser
    </button>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-3 orders-card">
    <div class="card-body p-3 p-lg-4">
      <div class="row g-2 align-items-center">
        <div class="col-12 col-lg-5">
          <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input class="form-control" id="ordersQ" placeholder="Réf / email / ID…" autocomplete="off">
          </div>
        </div>

        <div class="col-12 col-lg-3">
          <select class="form-select" id="ordersStatus">
            <option value="">Tous les statuts</option>
            {% for st in statuses %}
              <option value="{{ st }}">{{ st }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="col-12 col-lg-2">
          <select class="form-select" id="ordersLimit">
            <option value="15">15 / page</option>
            <option value="25">25 / page</option>
            <option value="50">50 / page</option>
          </select>
        </div>

        <div class="col-12 col-lg-2">
          <div class="d-flex justify-content-lg-end gap-2">
            <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis border border-primary-subtle px-3 py-2"
                  id="ordersCountBadge">—</span>
          </div>
        </div>
      </div>

      <div class="small text-muted mt-2" id="ordersHint"></div>
    </div>
  </div>

  <div id="ordersLoading" class="d-none">
    <div class="orders-skel mb-2"></div>
    <div class="orders-skel mb-2"></div>
    <div class="orders-skel mb-2"></div>
  </div>

  <div id="ordersEmpty" class="alert alert-light border rounded-4 d-none">
    <div class="d-flex gap-2 align-items-start">
      <i class="bi bi-inbox text-secondary mt-1"></i>
      <div>
        <div class="fw-semibold">Aucune commande</div>
        <div class="small text-muted">Aucun résultat pour ces filtres.</div>
      </div>
    </div>
  </div>

  <div id="ordersError" class="alert alert-danger rounded-4 d-none">
    <div class="d-flex gap-2 align-items-start">
      <i class="bi bi-exclamation-triangle-fill mt-1"></i>
      <div>
        <div class="fw-semibold">Erreur</div>
        <div class="small" id="ordersErrorMsg">Impossible de charger.</div>
      </div>
    </div>
  </div>

  <div id="ordersList" class="d-grid gap-2"></div>

  <div class="d-flex align-items-center justify-content-between gap-3 mt-3">
    <button class="btn btn-outline-secondary rounded-pill" id="ordersPrev" type="button" disabled>
      <i class="bi bi-chevron-left me-2"></i>Précédent
    </button>

    <div class="text-muted small" id="ordersPagerInfo">—</div>

    <button class="btn btn-outline-secondary rounded-pill" id="ordersNext" type="button" disabled>
      Suivant<i class="bi bi-chevron-right ms-2"></i>
    </button>
  </div>

</div>

{# Modal status #}
<div class="modal fade" id="statusModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 overflow-hidden">
      <div class="p-3 p-lg-4" style="background: linear-gradient(180deg, rgba(227,32,27,.10), rgba(255,255,255,0));">
        <div class="d-flex align-items-start justify-content-between gap-3">
          <div class="min-w-0">
            <div class="fw-black mb-1">Changer le statut</div>
            <div class="text-muted small" id="statusModalSub">—</div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="mt-3 d-grid gap-2" id="statusChoices"></div>

        <div class="text-muted small mt-3">
          ⚠️ Transitions verrouillées : pas de saut, pas de retour en arrière.
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.ADMIN_ORDERS_PAGE = {
    endpoint: "{{ path('admin_orders_ajax_list') }}",
    showUrlTpl: "{{ path('admin_orders_show', {id: 0})|replace({'0':'__ID__'}) }}",
    statusUrlTpl: "{{ path('admin_orders_ajax_status', {id: 0})|replace({'0':'__ID__'}) }}",
    csrf: "{{ csrf_token('admin_order_status') }}"
  };
</script>

<style>

/* Base un peu plus “chip pro” */
.order-status{
  display:inline-flex;
  align-items:center;
  gap:.45rem;
  font-weight: 900;
  letter-spacing:.01em;
}
.order-status::before{
  content:"";
  width:8px;height:8px;
  border-radius:999px;
  background: currentColor;
  opacity:.9;
}

/* Couleurs par statut (Bootstrap vars) */
.order-status[data-st="reserved"]{
  background: rgba(var(--bs-secondary-rgb), .10);
  border-color: rgba(var(--bs-secondary-rgb), .22);
  color: var(--bs-secondary);
}

.order-status[data-st="preparing"]{
  background: rgba(var(--bs-warning-rgb), .14);
  border-color: rgba(var(--bs-warning-rgb), .26);
  color: rgb(var(--bs-warning-rgb));
}

.order-status[data-st="ready"]{
  background: rgba(var(--bs-primary-rgb), .12);
  border-color: rgba(var(--bs-primary-rgb), .22);
  color: var(--bs-primary);
}

.order-status[data-st="shipped"]{
  background: rgba(var(--bs-info-rgb), .14);
  border-color: rgba(var(--bs-info-rgb), .26);
  color: rgb(var(--bs-info-rgb));
}

.order-status[data-st="delivered"]{
  background: rgba(var(--bs-success-rgb), .14);
  border-color: rgba(var(--bs-success-rgb), .26);
  color: rgb(var(--bs-success-rgb));
}

.order-status[data-st="cancelled"]{
  background: rgba(var(--bs-danger-rgb), .14);
  border-color: rgba(var(--bs-danger-rgb), .26);
  color: rgb(var(--bs-danger-rgb));
}

  .fw-black{ font-weight:900; }
  .orders-icon{
    width:44px;height:44px;border-radius:14px;display:grid;place-items:center;
    background: rgba(var(--bs-primary-rgb), .12);
    border: 1px solid rgba(var(--bs-primary-rgb), .18);
    color: var(--bs-primary);
    flex:0 0 auto;
  }
  .orders-card{ background: linear-gradient(180deg, rgba(var(--bs-primary-rgb), .06), rgba(255,255,255,0)); }

  .order-row{
    border: 1px solid rgba(0,0,0,.06);
    background:#fff;border-radius:18px;padding:14px 14px;
    transition: transform .12s ease, box-shadow .12s ease;
  }
  .order-row:hover{ transform: translateY(-1px); box-shadow: 0 .4rem 1rem rgba(0,0,0,.06); }
  .order-ref{ font-weight:900; }
  .order-meta{ color:#6c757d; font-size:.86rem; }
  .order-amount{ font-weight:900; }
  .order-status{
    font-size:.75rem;border-radius:999px;padding:.25rem .55rem;
    border:1px solid rgba(0,0,0,.08);
    background: rgba(108,117,125,.08);
    color:#495057; white-space:nowrap;
  }
  .orders-skel{
    height: 76px;border-radius:18px;
    background: linear-gradient(90deg, rgba(0,0,0,.05), rgba(0,0,0,.08), rgba(0,0,0,.05));
    background-size: 200% 100%;
    animation: ordersShimmer 1.2s infinite;
    border: 1px solid rgba(0,0,0,.06);
  }
  @keyframes ordersShimmer{ 0%{background-position:200% 0} 100%{background-position:-200% 0} }

  .status-choice{
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,.06);
    background: #fff;
    padding: 12px 14px;
    display:flex; align-items:center; justify-content:space-between; gap:12px;
    transition: transform .12s ease, box-shadow .12s ease;
    cursor:pointer;
  }
  .status-choice:hover{ transform: translateY(-1px); box-shadow: 0 .35rem 1rem rgba(0,0,0,.06); }
  .status-choice .hint{ color:#6c757d; font-size:.85rem; }
</style>
{% endblock %}

{% block javascripts %}
<script>
(function(){
  const CFG = window.ADMIN_ORDERS_PAGE || {};
  const endpoint = CFG.endpoint;

  const listEl = document.getElementById("ordersList");
  const loadingEl = document.getElementById("ordersLoading");
  const emptyEl = document.getElementById("ordersEmpty");
  const errorEl = document.getElementById("ordersError");
  const errorMsgEl = document.getElementById("ordersErrorMsg");
  const hintEl = document.getElementById("ordersHint");

  const qEl = document.getElementById("ordersQ");
  const stEl = document.getElementById("ordersStatus");
  const limEl = document.getElementById("ordersLimit");
  const badgeEl = document.getElementById("ordersCountBadge");

  const prevBtn = document.getElementById("ordersPrev");
  const nextBtn = document.getElementById("ordersNext");
  const pagerInfo = document.getElementById("ordersPagerInfo");
  const refreshBtn = document.getElementById("btnOrdersRefresh");

  const statusModalEl = document.getElementById("statusModal");
  const statusModalSub = document.getElementById("statusModalSub");
  const statusChoices = document.getElementById("statusChoices");
  const modal = statusModalEl ? bootstrap.Modal.getOrCreateInstance(statusModalEl) : null;

  let page = 1, pages = 1, total = 0;

  function escText(s){
    return String(s ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;");
  }
  function escAttr(s){
    return String(s ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#039;");
  }

  function debounce(fn, ms=250){ let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a), ms); }; }

  function fmtMoney(n){
    if(!Number.isFinite(n)) return "—";
    try{
      const LOCALE = window.CART_CONFIG?.locale || "fr-FR";
      const CURRENCY = window.CART_CONFIG?.currency || "MAD";
      return new Intl.NumberFormat(LOCALE,{style:"currency",currency:CURRENCY,maximumFractionDigits:2}).format(n);
    }catch(e){ return String(n); }
  }

  function setLoading(v){ loadingEl?.classList.toggle("d-none", !v); }
  function setEmpty(v){ emptyEl?.classList.toggle("d-none", !v); }
  function setError(msg){
    const show = !!msg;
    errorEl?.classList.toggle("d-none", !show);
    if(show && errorMsgEl) errorMsgEl.textContent = msg;
  }
  function updatePager(){
    pagerInfo && (pagerInfo.textContent = `Page ${page} / ${pages} • ${total} commande(s)`);
    prevBtn && (prevBtn.disabled = page <= 1);
    nextBtn && (nextBtn.disabled = page >= pages);
  }

  function showUrl(id){ return (CFG.showUrlTpl || "").replace("__ID__", String(id)); }
  function statusUrl(id){ return (CFG.statusUrlTpl || "").replace("__ID__", String(id)); }

 function statusChip(label, status){
  const txt = String(label || "").trim();
  const st  = String(status || "").trim();
  if(!txt) return "";
  return `<span class="order-status" data-st="${escAttr(st)}">${escText(txt)}</span>`;
}


  function renderList(orders){
    if(!listEl) return;
    listEl.innerHTML = "";

    for(const o of orders){
      const ref = o.reference || ("CMD-" + o.id);
      const date = o.createdAt || "";
      const amount = Number.isFinite(o.totalTtc) ? fmtMoney(o.totalTtc) : "—";
      const email = o.customer?.email ? o.customer.email : "—";
      const items = Number.isFinite(o.itemsCount) ? `${o.itemsCount} article(s)` : "—";
      const allowedStr = (o.allowedNext || []).join(",");

      const div = document.createElement("div");
      div.className = "order-row";

      div.innerHTML = `
        <div class="d-flex align-items-start justify-content-between gap-3">
          <div class="min-w-0">
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <a class="order-ref text-truncate text-decoration-none" href="${escAttr(showUrl(o.id))}">
                ${escText(ref)}
              </a>
            ${statusChip(o.statusLabel || o.status, o.status)}


              <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">${escText(items)}</span>
            </div>
            <div class="order-meta mt-1 text-truncate">
              <i class="bi bi-person me-1"></i>${escText(email)} &nbsp;•&nbsp;
              <i class="bi bi-clock me-1"></i>${escText(date)}
            </div>
          </div>

          <div class="text-end">
            <div class="order-amount text-nowrap">${escText(amount)}</div>
            <button class="btn btn-outline-secondary btn-sm rounded-pill mt-2"
                    data-action="status"
                    data-id="${escAttr(o.id)}"
                    data-ref="${escAttr(ref)}"
                    data-allowed="${escAttr(allowedStr)}">
              <i class="bi bi-pencil-square me-1"></i>Statut
            </button>
          </div>
        </div>
      `;

      listEl.appendChild(div);
    }
  }

  async function load(){
    if(!endpoint){
      setError("Endpoint manquant.");
      return;
    }

    setError("");
    setEmpty(false);
    setLoading(true);
    listEl && (listEl.innerHTML = "");

    const q = (qEl?.value || "").trim();
    const st = (stEl?.value || "").trim();
    const limit = parseInt(limEl?.value || "15", 10) || 15;

    if(hintEl){
      const parts = [];
      if(q) parts.push(`Recherche: "${q}"`);
      if(st) parts.push(`Statut: ${st}`);
      hintEl.textContent = parts.join(" • ");
    }

    const url = new URL(endpoint, window.location.origin);
    url.searchParams.set("page", String(page));
    url.searchParams.set("limit", String(limit));
    if(q) url.searchParams.set("q", q);
    if(st) url.searchParams.set("status", st);

    try{
      const res = await fetch(url.toString(), {
        credentials:"same-origin",
        cache:"no-store",
        headers:{ "Accept":"application/json", "X-Requested-With":"XMLHttpRequest" }
      });

      const data = await res.json().catch(()=>null);
      if(!res.ok || !data?.ok){
        badgeEl && (badgeEl.textContent = "—");
        setError(data?.message || "Impossible de charger les commandes.");
        return;
      }

      total = data.total || 0;
      pages = Math.max(1, data.pages || 1);
      page = Math.min(page, pages);

      badgeEl && (badgeEl.textContent = String(total));
      updatePager();

      const orders = data.orders || [];
      if(!orders.length){
        setEmpty(true);
        renderList([]);
        return;
      }

      renderList(orders);
    }catch(e){
      badgeEl && (badgeEl.textContent = "—");
      setError("Erreur réseau.");
    }finally{
      setLoading(false);
    }
  }

  function labelForStatus(st){
    const map = {
      reserved: "Reçue",
      preparing: "En préparation",
      ready: "Terminée",
      shipped: "Expédiée",
      delivered: "Livrée",
      cancelled: "Annulée",
    };
    return map[st] || st;
  }

  async function applyStatus(orderId, nextStatus){
    const url = statusUrl(orderId);

    const body = new URLSearchParams();
    body.set("status", nextStatus);
    body.set("_token", CFG.csrf || "");

    const res = await fetch(url, {
      method:"POST",
      credentials:"same-origin",
      headers:{
        "Content-Type":"application/x-www-form-urlencoded; charset=UTF-8",
        "X-Requested-With":"XMLHttpRequest",
        "Accept":"application/json",
        "X-CSRF-TOKEN": CFG.csrf || ""
      },
      body
    });

    const data = await res.json().catch(()=>null);
    if(!res.ok || !data?.ok){
      alert(data?.message || ("Erreur HTTP " + res.status));
      return false;
    }
    return true;
  }

  // Open modal (delegation)
  document.addEventListener("click", async (e) => {
    const btn = e.target.closest('[data-action="status"]');
    if(!btn) return;

    const id = btn.getAttribute("data-id");
    const ref = btn.getAttribute("data-ref") || ("CMD-" + id);
    const allowedStr = btn.getAttribute("data-allowed") || "";
    const allowed = allowedStr ? allowedStr.split(",").filter(Boolean) : [];

    if(statusModalSub) statusModalSub.textContent = `Commande ${ref}`;

    if(statusChoices){
      statusChoices.innerHTML = "";

      if(!allowed.length){
        statusChoices.innerHTML = `
          <div class="alert alert-light border rounded-4 mb-0">
            Aucun changement possible depuis ce statut.
          </div>
        `;
      }else{
        for(const st of allowed){
          const div = document.createElement("div");
          div.className = "status-choice";
          div.innerHTML = `
            <div class="min-w-0">
              <div class="fw-black">${escText(labelForStatus(st))}</div>
              <div class="hint">Appliquer : <b>${escText(st)}</b></div>
            </div>
            <i class="bi bi-arrow-right"></i>
          `;

          div.addEventListener("click", async () => {
            div.style.pointerEvents = "none";
            div.style.opacity = ".7";

            const ok = await applyStatus(id, st);
            if(ok){
              modal?.hide();
              await load();
            }else{
              div.style.pointerEvents = "";
              div.style.opacity = "";
            }
          });

          statusChoices.appendChild(div);
        }
      }
    }

    modal?.show();
  });

  // Events
  const loadDebounced = debounce(()=>{ page = 1; load(); }, 260);
  qEl?.addEventListener("input", loadDebounced);
  stEl?.addEventListener("change", ()=>{ page=1; load(); });
  limEl?.addEventListener("change", ()=>{ page=1; load(); });

  prevBtn?.addEventListener("click", ()=>{ page = Math.max(1, page-1); load(); });
  nextBtn?.addEventListener("click", ()=>{ page = Math.min(pages, page+1); load(); });
  refreshBtn?.addEventListener("click", ()=> load());

  // ✅ init robuste (avec ou sans Turbo)
  function init(){
    load();
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
  document.addEventListener("turbo:load", init);

})();
</script>
{% endblock %}
