{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{% block title %}EBPToWeb{% endblock %}</title>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  

  <link rel="stylesheet" href="{{ asset('styles/app.css') }}">

  {% block stylesheets %}{% endblock %}
</head>

<body>
  {% include 'partials/_topbar.html.twig' %}
  {% include 'partials/_menu.html.twig' %}
  {% include 'partials/_cart_offcanvas.html.twig' %}
  {% include 'partials/_toast_zone.html.twig' %}

  <main class="container-fluid py-3">
    {% block body %}{% endblock %}
  </main>
	{% include 'home/sections/_footer.html.twig' %}
	{% include 'home/sections/_login_gate_modal.html.twig' %}
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    window.CART_ENDPOINTS = {
      state: "{{ path('cart_state') }}",
      add: "{{ path('cart_add') }}",
      set: "{{ path('cart_set') }}",
      remove: "{{ path('cart_remove') }}",
      clear: "{{ path('cart_clear') }}",
      index: "{{ path('cart_index') }}"
    };
  </script>

  {# ✅ panier global (sans prix/total) #}
<script>
  window.CART_CONFIG = {
    csvUrl: "{{ path('catalogue_csv') }}",
    imagesBase: "https://catalogue.3skpartsauto.com/export_images",
    locale: "fr-FR",
    currency: "MAD"
  };
</script>

<script src="https://cdn.jsdelivr.net/npm/papaparse@5.4.1/papaparse.min.js"></script>
<script src="{{ asset('js/cart-ui.js') }}"></script>
<script>
  window.CART_CONFIG = {
    csvUrl: "{{ csvUrl|default(path('catalogue_csv'))|e('js') }}",
    imagesBase: "{{ imagesBase|default('https://catalogue.3skpartsauto.com/export_images')|e('js') }}",
    locale: "fr-FR",
    currency: "MAD"
  };
</script>


<script src="{{ asset('js/my-orders-widget.js') }}"></script>


  {% block javascripts %}{% endblock %}
</body>
</html>
